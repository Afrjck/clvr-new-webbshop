{% doc %}
  @prompt
    Create a premium animated contact section for a streetwear brand. The section should have a bold heading "Get in Touch" that fades in on scroll, followed by a short description text that slides in. Include an email address (clv3r4@gmail.com) displayed with a subtle hover glow effect. Add a response time note "We respond within 24 hours on business days." The overall aesthetic should be dark, minimal, and premium streetwear — think clean typography, dark background, white text, with smooth CSS animations. No contact form needed, just the info block with animations.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-contact-section-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
    text-align: center;
  }

  .ai-contact-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-contact-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    font-weight: {{ block.settings.heading_weight }};
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.heading_spacing }}px;
    letter-spacing: {{ block.settings.heading_letter_spacing }}px;
    text-transform: {{ block.settings.heading_transform }};
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.8s ease, transform 0.8s ease;
  }

  .ai-contact-heading-{{ ai_gen_id }}.ai-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .ai-contact-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    margin: 0 0 {{ block.settings.description_spacing }}px;
    line-height: 1.6;
    opacity: 0;
    transform: translateX(-30px);
    transition: opacity 0.8s ease 0.2s, transform 0.8s ease 0.2s;
  }

  .ai-contact-description-{{ ai_gen_id }}.ai-visible {
    opacity: 1;
    transform: translateX(0);
  }

  .ai-contact-email-wrapper-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.email_spacing }}px;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.8s ease 0.4s, transform 0.8s ease 0.4s;
  }

  .ai-contact-email-wrapper-{{ ai_gen_id }}.ai-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .ai-contact-email-{{ ai_gen_id }} {
    display: inline-block;
    font-size: {{ block.settings.email_size }}px;
    color: {{ block.settings.email_color }};
    text-decoration: none;
    font-weight: {{ block.settings.email_weight }};
    letter-spacing: {{ block.settings.email_letter_spacing }}px;
    position: relative;
    transition: color 0.3s ease;
  }

  .ai-contact-email-{{ ai_gen_id }}::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 100%;
    height: 1px;
    background-color: {{ block.settings.email_color }};
    opacity: 0.3;
    transition: opacity 0.3s ease;
  }

  .ai-contact-email-{{ ai_gen_id }}:hover {
    color: {{ block.settings.email_hover_color }};
    text-shadow: 0 0 {{ block.settings.glow_intensity }}px {{ block.settings.email_hover_color }};
  }

  .ai-contact-email-{{ ai_gen_id }}:hover::after {
    opacity: 1;
    background-color: {{ block.settings.email_hover_color }};
    box-shadow: 0 0 {{ block.settings.glow_intensity }}px {{ block.settings.email_hover_color }};
  }

  .ai-contact-note-{{ ai_gen_id }} {
    font-size: {{ block.settings.note_size }}px;
    color: {{ block.settings.note_color }};
    margin: 0;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.8s ease 0.6s, transform 0.8s ease 0.6s;
  }

  .ai-contact-note-{{ ai_gen_id }}.ai-visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media screen and (max-width: 749px) {
    .ai-contact-section-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_top | times: 0.6 }}px {{ block.settings.padding_horizontal | times: 0.6 }}px {{ block.settings.padding_bottom | times: 0.6 }}px;
    }

    .ai-contact-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-contact-description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_size | times: 0.9 }}px;
    }

    .ai-contact-email-{{ ai_gen_id }} {
      font-size: {{ block.settings.email_size | times: 0.8 }}px;
    }

    .ai-contact-note-{{ ai_gen_id }} {
      font-size: {{ block.settings.note_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<contact-section-{{ ai_gen_id }} class="ai-contact-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-contact-container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-contact-heading-{{ ai_gen_id }}" data-animate>
        {{ block.settings.heading }}
      </h2>
    {% endif %}

    {% if block.settings.description != blank %}
      <div class="ai-contact-description-{{ ai_gen_id }}" data-animate>
        {{ block.settings.description }}
      </div>
    {% endif %}

    {% if block.settings.email != blank %}
      <div class="ai-contact-email-wrapper-{{ ai_gen_id }}" data-animate>
        <a href="mailto:{{ block.settings.email }}" class="ai-contact-email-{{ ai_gen_id }}">
          {{ block.settings.email }}
        </a>
      </div>
    {% endif %}

    {% if block.settings.note != blank %}
      <p class="ai-contact-note-{{ ai_gen_id }}" data-animate>
        {{ block.settings.note }}
      </p>
    {% endif %}
  </div>
</contact-section-{{ ai_gen_id }}>

<script>
  (function() {
    class ContactSection{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.observer = null;
      }

      connectedCallback() {
        this.setupIntersectionObserver();
      }

      setupIntersectionObserver() {
        const options = {
          root: null,
          rootMargin: '0px',
          threshold: 0.2
        };

        this.observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              const animateElements = this.querySelectorAll('[data-animate]');
              animateElements.forEach((element) => {
                element.classList.add('ai-visible');
              });
              this.observer.unobserve(entry.target);
            }
          });
        }, options);

        this.observer.observe(this);
      }

      disconnectedCallback() {
        if (this.observer) {
          this.observer.disconnect();
        }
      }
    }

    customElements.define('contact-section-{{ ai_gen_id }}', ContactSection{{ ai_gen_id }});
  })();
</script>

