{% doc %}
  @prompt
    Add a payment icons row on the product page, displayed directly below the 'Add to Cart' button. Show the standard payment method icons (Visa, Mastercard, iDEAL, PayPal, American Express, etc.) in a horizontal row, centered or left-aligned, small size. Style it to look clean and minimal, matching a premium streetwear brand aesthetic. Use Shopify's built-in payment icons where possible.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-payment-icons-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin-top: {{ block.settings.spacing_top }}px;
  }

  .ai-payment-icons-wrapper-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    gap: {{ block.settings.icon_spacing }}px;
    align-items: center;
    {% if block.settings.alignment == 'left' %}
      justify-content: flex-start;
    {% elsif block.settings.alignment == 'center' %}
      justify-content: center;
    {% else %}
      justify-content: flex-end;
    {% endif %}
  }

  .ai-payment-icon-{{ ai_gen_id }} {
    height: {{ block.settings.icon_size }}px;
    width: auto;
    opacity: {{ block.settings.icon_opacity }};
    transition: opacity 0.2s ease;
  }

  .ai-payment-icon-{{ ai_gen_id }}:hover {
    opacity: 1;
  }

  .ai-payment-icon-{{ ai_gen_id }} svg {
    height: 100%;
    width: auto;
    display: block;
  }

  @media screen and (max-width: 749px) {
    .ai-payment-icons-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-payment-icons-wrapper-{{ ai_gen_id }} {
      gap: {{ block.settings.icon_spacing | times: 0.8 }}px;
    }

    .ai-payment-icon-{{ ai_gen_id }} {
      height: {{ block.settings.icon_size | times: 0.85 }}px;
    }
  }
{% endstyle %}

<div class="ai-payment-icons-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-payment-icons-wrapper-{{ ai_gen_id }}">
    {% for type in shop.enabled_payment_types %}
      <div class="ai-payment-icon-{{ ai_gen_id }}">
        {{ type | payment_type_svg_tag }}
      </div>
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Payment icons",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "spacing_top",
      "label": "Top spacing",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Icon style"
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon height",
      "min": 16,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "icon_spacing",
      "label": "Icon spacing",
      "min": 4,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "icon_opacity",
      "label": "Icon opacity",
      "min": 0.3,
      "max": 1,
      "step": 0.1,
      "default": 0.6
    }
  ],
  "presets": [
    {
      "name": "Payment icons"
    }
  ]
}
{% endschema %}
