{% doc %}
  @prompt
    Create a World Cup prediction widget section for a Shopify page with a dark premium streetwear aesthetic. Use EXACTLY the same layout structure as previously built versions of this widget for this store.
    
    LAYOUT STRUCTURE (must match exactly):
    - Full-width dark section, content centered in a max-width container
    - Top: contest header text
    - Below header: countdown timer with 4 boxes side by side (Days | Hours | Minutes | Seconds), each box has a large number and a small label underneath, gold border accent
    - Below timer: gold scarcity badge/pill
    - Below badge: form (email field full width, two score inputs side by side with team labels, goalscorers text field full width, full-width gold submit button)
    - Below form: success message (hidden until submit)
    - Below form: prizes section with two rows of prize text with emoji icons
    - All elements left-aligned within the container, generous padding
    
    DESIGN:
    - Dark background #000000, white text, gold accent #c9a84c
    - Minimal, editorial typography (clean sans-serif)
    - Form inputs: dark background #1a1a1a, subtle border #333333, white text
    - Submit button: gold background #c9a84c, black text, full width
    - Countdown boxes: dark background with gold border 2px solid #c9a84c
    
    CONTENT (ALL TEXT IN ENGLISH):
    - Header: "Morocco vs Haiti — June 25, 2026"
    - Live countdown timer to June 24 2026 23:50 CEST (June 24 2026 21:50 UTC) — boxes labeled "Days", "Hours", "Minutes", "Seconds"
    - After deadline show "Submissions are closed." and hide the form
    - Scarcity badge: "~12 shirts remaining" in gold
    - Form fields:
      - Email (required, label: "Your email address")
      - Two side-by-side number inputs labeled "Morocco" and "Haiti" (min 0, integers only)
      - Optional text field: "Goalscorers (optional)" with placeholder "e.g. Hakimi, En-Nesyri, Laguerre — comma-separated"
      - Submit button: "Enter now"
    - Success message: "Your prediction has been saved! We'll let you know if you've won."
    - Prizes:
      - "🎯 Correct score → €15 discount"
      - "🏆 Correct score + goalscorer → Free shirt"
    
    FUNCTIONALITY:
    - Deadline: June 24 2026 23:50 CEST = June 24 2026 21:50:00 UTC
    - After deadline: hide form, show "Submissions are closed."
    - On submit: use fetch POST to /account with form_type create_customer, save customer email, add tags "wk-voorspelling" and "mar-hai-2026", store prediction in customer note
    - DUPLICATE CHECK: only show "You've already entered!" if the email has ALREADY submitted a prediction for this contest (has tag mar-hai-2026 AND stored prediction). Do NOT block existing customers who have not yet submitted.
    - All text in English
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-wc-widget-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: #000000;
    padding: 60px 20px;
  }

  .ai-wc-container-{{ ai_gen_id }} {
    max-width: 600px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .ai-wc-header-{{ ai_gen_id }} {
    color: #ffffff;
    font-size: 28px;
    font-weight: 600;
    margin: 0;
    text-align: left;
    letter-spacing: -0.5px;
  }

  .ai-wc-countdown-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
  }

  .ai-wc-countdown-box-{{ ai_gen_id }} {
    background-color: #000000;
    border: 2px solid #c9a84c;
    border-radius: 8px;
    padding: 20px 12px;
    text-align: center;
  }

  .ai-wc-countdown-number-{{ ai_gen_id }} {
    color: #ffffff;
    font-size: 36px;
    font-weight: 700;
    line-height: 1;
    margin: 0 0 8px 0;
  }

  .ai-wc-countdown-label-{{ ai_gen_id }} {
    color: #c9a84c;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    font-weight: 500;
  }

  .ai-wc-scarcity-{{ ai_gen_id }} {
    display: inline-block;
    background-color: #c9a84c;
    color: #000000;
    padding: 10px 20px;
    border-radius: 20px;
    font-size: 14px;
    font-weight: 600;
    text-align: left;
  }

  .ai-wc-form-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .ai-wc-input-{{ ai_gen_id }} {
    width: 100%;
    padding: 14px 16px;
    background-color: #1a1a1a;
    border: 1px solid #333333;
    border-radius: 6px;
    color: #ffffff;
    font-size: 15px;
  }

  .ai-wc-input-{{ ai_gen_id }}::placeholder {
    color: #666666;
  }

  .ai-wc-input-{{ ai_gen_id }}:focus {
    outline: none;
    border-color: #c9a84c;
  }

  .ai-wc-score-row-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  .ai-wc-score-field-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ai-wc-label-{{ ai_gen_id }} {
    color: #ffffff;
    font-size: 13px;
    font-weight: 500;
  }

  .ai-wc-submit-{{ ai_gen_id }} {
    width: 100%;
    padding: 16px;
    background-color: #c9a84c;
    color: #000000;
    border: none;
    border-radius: 6px;
    font-size: 16px;
    font-weight: 700;
    cursor: pointer;
    transition: opacity 0.2s;
  }

  .ai-wc-submit-{{ ai_gen_id }}:hover {
    opacity: 0.9;
  }

  .ai-wc-submit-{{ ai_gen_id }}:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .ai-wc-message-{{ ai_gen_id }} {
    padding: 16px;
    border-radius: 6px;
    font-size: 15px;
    text-align: center;
    display: none;
  }

  .ai-wc-message-{{ ai_gen_id }}.active {
    display: block;
  }

  .ai-wc-success-{{ ai_gen_id }} {
    background-color: rgba(201, 168, 76, 0.1);
    border: 1px solid #c9a84c;
    color: #c9a84c;
  }

  .ai-wc-error-{{ ai_gen_id }} {
    background-color: rgba(255, 77, 77, 0.1);
    border: 1px solid #ff4d4d;
    color: #ff4d4d;
  }

  .ai-wc-closed-{{ ai_gen_id }} {
    color: #999999;
    font-size: 16px;
    text-align: center;
    padding: 20px;
    display: none;
  }

  .ai-wc-closed-{{ ai_gen_id }}.active {
    display: block;
  }

  .ai-wc-prizes-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .ai-wc-prize-{{ ai_gen_id }} {
    color: #ffffff;
    font-size: 15px;
    line-height: 1.5;
  }

  @media screen and (max-width: 600px) {
    .ai-wc-header-{{ ai_gen_id }} {
      font-size: 22px;
    }

    .ai-wc-countdown-{{ ai_gen_id }} {
      gap: 8px;
    }

    .ai-wc-countdown-box-{{ ai_gen_id }} {
      padding: 16px 8px;
    }

    .ai-wc-countdown-number-{{ ai_gen_id }} {
      font-size: 28px;
    }

    .ai-wc-countdown-label-{{ ai_gen_id }} {
      font-size: 10px;
    }
  }
{% endstyle %}

<wc-prediction-widget-{{ ai_gen_id }} class="ai-wc-widget-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-wc-container-{{ ai_gen_id }}">
    <h2 class="ai-wc-header-{{ ai_gen_id }}">Morocco vs Haiti — June 25, 2026</h2>

    <div class="ai-wc-countdown-{{ ai_gen_id }}" data-deadline="2026-06-24T21:50:00Z">
      <div class="ai-wc-countdown-box-{{ ai_gen_id }}">
        <div class="ai-wc-countdown-number-{{ ai_gen_id }}" data-unit="days">0</div>
        <div class="ai-wc-countdown-label-{{ ai_gen_id }}">Days</div>
      </div>
      <div class="ai-wc-countdown-box-{{ ai_gen_id }}">
        <div class="ai-wc-countdown-number-{{ ai_gen_id }}" data-unit="hours">0</div>
        <div class="ai-wc-countdown-label-{{ ai_gen_id }}">Hours</div>
      </div>
      <div class="ai-wc-countdown-box-{{ ai_gen_id }}">
        <div class="ai-wc-countdown-number-{{ ai_gen_id }}" data-unit="minutes">0</div>
        <div class="ai-wc-countdown-label-{{ ai_gen_id }}">Minutes</div>
      </div>
      <div class="ai-wc-countdown-box-{{ ai_gen_id }}">
        <div class="ai-wc-countdown-number-{{ ai_gen_id }}" data-unit="seconds">0</div>
        <div class="ai-wc-countdown-label-{{ ai_gen_id }}">Seconds</div>
      </div>
    </div>

    <div class="ai-wc-scarcity-{{ ai_gen_id }}">~12 shirts remaining</div>

    <div class="ai-wc-closed-{{ ai_gen_id }}">Submissions are closed.</div>

    <form class="ai-wc-form-{{ ai_gen_id }}" data-form>
      <div>
        <label class="ai-wc-label-{{ ai_gen_id }}" for="ai-wc-email-{{ ai_gen_id }}">Your email address</label>
        <input
          type="email"
          id="ai-wc-email-{{ ai_gen_id }}"
          class="ai-wc-input-{{ ai_gen_id }}"
          required
          autocomplete="email"
        >
      </div>

      <div class="ai-wc-score-row-{{ ai_gen_id }}">
        <div class="ai-wc-score-field-{{ ai_gen_id }}">
          <label class="ai-wc-label-{{ ai_gen_id }}" for="ai-wc-morocco-{{ ai_gen_id }}">Morocco</label>
          <input
            type="number"
            id="ai-wc-morocco-{{ ai_gen_id }}"
            class="ai-wc-input-{{ ai_gen_id }}"
            min="0"
            step="1"
            required
          >
        </div>
        <div class="ai-wc-score-field-{{ ai_gen_id }}">
          <label class="ai-wc-label-{{ ai_gen_id }}" for="ai-wc-haiti-{{ ai_gen_id }}">Haiti</label>
          <input
            type="number"
            id="ai-wc-haiti-{{ ai_gen_id }}"
            class="ai-wc-input-{{ ai_gen_id }}"
            min="0"
            step="1"
            required
          >
        </div>
      </div>

      <div>
        <label class="ai-wc-label-{{ ai_gen_id }}" for="ai-wc-goalscorers-{{ ai_gen_id }}">Goalscorers (optional)</label>
        <input
          type="text"
          id="ai-wc-goalscorers-{{ ai_gen_id }}"
          class="ai-wc-input-{{ ai_gen_id }}"
          placeholder="e.g. Hakimi, En-Nesyri, Laguerre — comma-separated"
        >
      </div>

      <button type="submit" class="ai-wc-submit-{{ ai_gen_id }}">Enter now</button>
    </form>

    <div class="ai-wc-message-{{ ai_gen_id }} ai-wc-success-{{ ai_gen_id }}" data-success>
      Your prediction has been saved! We'll let you know if you've won.
    </div>

    <div class="ai-wc-message-{{ ai_gen_id }} ai-wc-error-{{ ai_gen_id }}" data-error></div>

    <div class="ai-wc-prizes-{{ ai_gen_id }}">
      <div class="ai-wc-prize-{{ ai_gen_id }}">🎯 Correct score → €15 discount</div>
      <div class="ai-wc-prize-{{ ai_gen_id }}">🏆 Correct score + goalscorer → Free shirt</div>
    </div>
  </div>
</wc-prediction-widget-{{ ai_gen_id }}>

<script>
  (function() {
    class WCPredictionWidget{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.deadline = new Date('2026-06-24T21:50:00Z');
        this.countdownEl = this.querySelector('[data-deadline]');
        this.form = this.querySelector('[data-form]');
        this.successMsg = this.querySelector('[data-success]');
        this.errorMsg = this.querySelector('[data-error]');
        this.closedMsg = this.querySelector('.ai-wc-closed-{{ ai_gen_id }}');
        this.submittedEmails = new Set();
      }

      connectedCallback() {
        this.updateCountdown();
        this.countdownInterval = setInterval(() => this.updateCountdown(), 1000);
        this.form.addEventListener('submit', (e) => this.handleSubmit(e));
        this.loadSubmittedEmails();
      }

      disconnectedCallback() {
        if (this.countdownInterval) {
          clearInterval(this.countdownInterval);
        }
      }

      loadSubmittedEmails() {
        const stored = localStorage.getItem('wc_mar_hai_2026_emails');
        if (stored) {
          try {
            const emails = JSON.parse(stored);
            this.submittedEmails = new Set(emails);
          } catch (e) {
            this.submittedEmails = new Set();
          }
        }
      }

      saveSubmittedEmail(email) {
        this.submittedEmails.add(email.toLowerCase());
        localStorage.setItem('wc_mar_hai_2026_emails', JSON.stringify([...this.submittedEmails]));
      }

      updateCountdown() {
        const now = new Date();
        const diff = this.deadline - now;

        if (diff <= 0) {
          this.showClosed();
          return;
        }

        const days = Math.floor(diff / (1000 * 60 * 60 * 24));
        const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
        const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
        const seconds = Math.floor((diff % (1000 * 60)) / 1000);

        this.querySelector('[data-unit="days"]').textContent = days;
        this.querySelector('[data-unit="hours"]').textContent = hours;
        this.querySelector('[data-unit="minutes"]').textContent = minutes;
        this.querySelector('[data-unit="seconds"]').textContent = seconds;
      }

      showClosed() {
        if (this.countdownInterval) {
          clearInterval(this.countdownInterval);
        }
        this.form.style.display = 'none';
        this.closedMsg.classList.add('active');
      }

      async handleSubmit(e) {
        e.preventDefault();

        const emailInput = this.querySelector('#ai-wc-email-{{ ai_gen_id }}');
        const moroccoInput = this.querySelector('#ai-wc-morocco-{{ ai_gen_id }}');
        const haitiInput = this.querySelector('#ai-wc-haiti-{{ ai_gen_id }}');
        const goalscorersInput = this.querySelector('#ai-wc-goalscorers-{{ ai_gen_id }}');

        const email = emailInput.value.trim().toLowerCase();
        const morocco = moroccoInput.value;
        const haiti = haitiInput.value;
        const goalscorers = goalscorersInput.value.trim();

        if (this.submittedEmails.has(email)) {
          this.showError("You've already entered!");
          return;
        }

        const now = new Date();
        if (now >= this.deadline) {
          this.showError('Submissions are closed.');
          return;
        }

        const submitButton = this.form.querySelector('button[type="submit"]');
        submitButton.disabled = true;
        submitButton.textContent = 'Submitting...';

        const predictionData = {
          score: morocco + '-' + haiti,
          goalscorers: goalscorers || 'None',
          timestamp: new Date().toISOString()
        };

        const formData = new FormData();
        formData.append('form_type', 'create_customer');
        formData.append('utf8', '✓');
        formData.append('customer[email]', email);
        formData.append('customer[tags]', 'wk-voorspelling,mar-hai-2026');
        formData.append('customer[note]', 'Morocco vs Haiti prediction: ' + JSON.stringify(predictionData));

        try {
          const response = await fetch('/account', {
            method: 'POST',
            body: formData,
            headers: {
              'Accept': 'application/json'
            }
          });

          this.saveSubmittedEmail(email);
          this.showSuccess();
          this.form.reset();
        } catch (error) {
          this.showError('Something went wrong. Please try again.');
        } finally {
          submitButton.disabled = false;
          submitButton.textContent = 'Enter now';
        }
      }

      showSuccess() {
        this.successMsg.classList.add('active');
        this.errorMsg.classList.remove('active');
        setTimeout(() => {
          this.successMsg.classList.remove('active');
        }, 5000);
      }

      showError(message) {
        this.errorMsg.textContent = message;
        this.errorMsg.classList.add('active');
        this.successMsg.classList.remove('active');
        setTimeout(() => {
          this.errorMsg.classList.remove('active');
        }, 5000);
      }
    }

    customElements.define('wc-prediction-widget-{{ ai_gen_id }}', WCPredictionWidget{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "World Cup prediction",
  "settings": [],
  "presets": [
    {
      "name": "World Cup prediction"
    }
  ]
}
{% endschema %}
