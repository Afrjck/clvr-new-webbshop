      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Achtergrondkleur",
      "default": "#0a0a0a"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Tekstkleur",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accentkleur",
      "default": "#c9a84c"
    },
    {
      "type": "color",
      "id": "input_background",
      "label": "Invoerveld achtergrond",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "input_border",
      "label": "Invoerveld rand",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Knop kleur",
      "default": "#c9a84c"
    },
    {
      "type": "color",
