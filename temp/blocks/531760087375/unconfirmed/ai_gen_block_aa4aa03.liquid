{% doc %}
  @prompt
    Create an interactive vertical timeline section that highlights as the user scrolls. Each timeline item has a year/date, a title, and a short description. The active item highlights with a glowing accent color as it enters the viewport during scrolling. Clean, minimal, premium streetwear aesthetic with dark background and white/gold text. The timeline items should be customizable in the theme editor (date, title, description). Smooth scroll-triggered animations.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-timeline-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding }}px 20px;
  }

  .ai-timeline-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    position: relative;
    width: {{ block.settings.desktop_width_percent }}%;
  }

  .ai-timeline-line-{{ ai_gen_id }} {
    position: absolute;
    left: 50%;
    top: 0;
    bottom: 0;
    width: 2px;
    background: linear-gradient(
      to bottom,
      transparent 0%,
      {{ block.settings.line_color }} 10%,
      {{ block.settings.line_color }} 90%,
      transparent 100%
    );
    transform: translateX(-50%);
  }

  .ai-timeline-items-{{ ai_gen_id }} {
    position: relative;
    z-index: 1;
  }

  .ai-timeline-item-{{ ai_gen_id }} {
    position: relative;
    margin-bottom: {{ block.settings.item_spacing }}px;
    opacity: 0.4;
    transform: translateY(30px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }

  .ai-timeline-item-{{ ai_gen_id }}.active {
    opacity: 1;
    transform: translateY(0);
  }

  .ai-timeline-item-{{ ai_gen_id }}:nth-child(odd) .ai-timeline-content-{{ ai_gen_id }} {
    margin-left: 0;
    margin-right: calc(50% + 40px);
    text-align: right;
  }

  .ai-timeline-item-{{ ai_gen_id }}:nth-child(even) .ai-timeline-content-{{ ai_gen_id }} {
    margin-left: calc(50% + 40px);
    margin-right: 0;
    text-align: left;
  }

  .ai-timeline-content-{{ ai_gen_id }} {
    padding: {{ block.settings.content_padding }}px;
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.border_radius }}px;
    position: relative;
  }

  .ai-timeline-item-{{ ai_gen_id }}.active .ai-timeline-content-{{ ai_gen_id }} {
    box-shadow: 0 0 {{ block.settings.glow_size }}px {{ block.settings.glow_color }};
  }

  .ai-timeline-dot-{{ ai_gen_id }} {
    position: absolute;
    left: 50%;
    top: 30px;
    width: {{ block.settings.dot_size }}px;
    height: {{ block.settings.dot_size }}px;
    background-color: {{ block.settings.dot_color }};
    border: 3px solid {{ block.settings.background_color }};
    border-radius: 50%;
    transform: translate(-50%, -50%);
    z-index: 2;
    transition: all 0.6s ease;
  }

  .ai-timeline-item-{{ ai_gen_id }}.active .ai-timeline-dot-{{ ai_gen_id }} {
    background-color: {{ block.settings.glow_color }};
    box-shadow: 0 0 {{ block.settings.glow_size }}px {{ block.settings.glow_color }};
    transform: translate(-50%, -50%) scale(1.3);
  }

  .ai-timeline-date-{{ ai_gen_id }} {
    font-size: {{ block.settings.date_size }}px;
    color: {{ block.settings.accent_color }};
    font-weight: 700;
    margin-bottom: 12px;
    letter-spacing: 1px;
  }

  .ai-timeline-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    font-weight: 600;
    margin-bottom: 12px;
    line-height: 1.2;
  }

  .ai-timeline-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.5;
  }

  @media screen and (max-width: 768px) {
    .ai-timeline-line-{{ ai_gen_id }} {
      left: 20px;
    }

    .ai-timeline-dot-{{ ai_gen_id }} {
      left: 20px;
    }

    .ai-timeline-item-{{ ai_gen_id }}:nth-child(odd) .ai-timeline-content-{{ ai_gen_id }},
    .ai-timeline-item-{{ ai_gen_id }}:nth-child(even) .ai-timeline-content-{{ ai_gen_id }} {
      margin-left: 60px;
      margin-right: 0;
      text-align: left;
    }
  }
{% endstyle %}

<timeline-scroll-{{ ai_gen_id }} class="ai-timeline-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-timeline-container-{{ ai_gen_id }}">
    <div class="ai-timeline-line-{{ ai_gen_id }}"></div>
    <div class="ai-timeline-items-{{ ai_gen_id }}">
      {% for i in (1..6) %}
        {% liquid
          assign date_key = 'item_' | append: i | append: '_date'
          assign title_key = 'item_' | append: i | append: '_title'
          assign description_key = 'item_' | append: i | append: '_description'
          assign enabled_key = 'item_' | append: i | append: '_enabled'

          assign item_date = block.settings[date_key]
          assign item_title = block.settings[title_key]
          assign item_description = block.settings[description_key]
          assign item_enabled = block.settings[enabled_key]
        %}

        {% if item_enabled %}
          <div class="ai-timeline-item-{{ ai_gen_id }}" data-timeline-item>
            <div class="ai-timeline-dot-{{ ai_gen_id }}"></div>
            <div class="ai-timeline-content-{{ ai_gen_id }}">
              {% if item_date != blank %}
                <div class="ai-timeline-date-{{ ai_gen_id }}">{{ item_date }}</div>
              {% endif %}
              {% if item_title != blank %}
                <h3 class="ai-timeline-title-{{ ai_gen_id }}">{{ item_title }}</h3>
              {% endif %}
              {% if item_description != blank %}
                <div class="ai-timeline-description-{{ ai_gen_id }}">{{ item_description }}</div>
              {% endif %}
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</timeline-scroll-{{ ai_gen_id }}>

<script>
  (function() {
    class TimelineScroll{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.items = [];
        this.observer = null;
      }

      connectedCallback() {
        this.items = Array.from(this.querySelectorAll('[data-timeline-item]'));
        this.setupIntersectionObserver();
      }

      setupIntersectionObserver() {
        const options = {
          root: null,
          rootMargin: '-20% 0px -20% 0px',
          threshold: [0, 0.25, 0.5, 0.75, 1]
        };

        this.observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting && entry.intersectionRatio > 0.3) {
              entry.target.classList.add('active');
            } else if (entry.intersectionRatio < 0.1) {
              entry.target.classList.remove('active');
            }
          });
        }, options);

        this.items.forEach((item) => {
          this.observer.observe(item);
        });
      }

      disconnectedCallback() {
        if (this.observer) {
          this.observer.disconnect();
        }
      }
    }

    customElements.define('timeline-scroll-{{ ai_gen_id }}', TimelineScroll{{ ai_gen_id }});
  })();
</script>

