{% doc %}
  @prompt
    Create a compact email newsletter signup block for the footer of a luxury streetwear store. It must include: a spaced-out uppercase heading "JOIN THE CLUB.", a short subtext "Join and enter to win a gift card worth €150", an inline email input field with placeholder "Enter your email address" and an envelope icon button on the right to submit. When submitted, the email should be added to the Shopify email marketing subscribers list. Style: minimal and elegant, cream/off-white text, no heavy borders, understated luxury feel. Must be compact enough to fit as a footer column block.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-newsletter-footer-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    max-width: 100%;
  }

  .ai-newsletter-footer__heading-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.text_color }};
    text-transform: uppercase;
    letter-spacing: {{ block.settings.letter_spacing }}px;
    margin: 0 0 {{ block.settings.heading_spacing }}px 0;
    line-height: 1.2;
  }

  .ai-newsletter-footer__subtext-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtext_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 {{ block.settings.subtext_spacing }}px 0;
    line-height: 1.4;
    opacity: 0.9;
  }

  .ai-newsletter-footer__form-wrapper-{{ ai_gen_id }} {
    position: relative;
  }

  .ai-newsletter-footer__input-wrapper-{{ ai_gen_id }} {
    position: relative;
    display: flex;
    align-items: center;
    border-bottom: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
    transition: border-color 0.3s ease;
  }

  .ai-newsletter-footer__input-wrapper-{{ ai_gen_id }}:focus-within {
    border-color: {{ block.settings.border_focus_color }};
  }

  .ai-newsletter-footer__input-{{ ai_gen_id }} {
    flex: 1;
    background: transparent;
    border: none;
    padding: {{ block.settings.input_padding }}px 0;
    font-size: {{ block.settings.input_size }}px;
    color: {{ block.settings.text_color }};
    outline: none;
    font-family: inherit;
  }

  .ai-newsletter-footer__input-{{ ai_gen_id }}::placeholder {
    color: {{ block.settings.text_color }};
    opacity: 0.6;
  }

  .ai-newsletter-footer__button-{{ ai_gen_id }} {
    background: transparent;
    border: none;
    padding: {{ block.settings.input_padding }}px 0 {{ block.settings.input_padding }}px 12px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.3s ease;
  }

  .ai-newsletter-footer__button-{{ ai_gen_id }}:hover {
    opacity: 0.7;
  }

  .ai-newsletter-footer__button-{{ ai_gen_id }} svg {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    stroke: {{ block.settings.text_color }};
    fill: none;
    stroke-width: 2;
  }

  .ai-newsletter-footer__message-{{ ai_gen_id }} {
    font-size: {{ block.settings.message_size }}px;
    margin-top: 8px;
    line-height: 1.4;
  }

  .ai-newsletter-footer__success-{{ ai_gen_id }} {
    color: {{ block.settings.success_color }};
  }

  .ai-newsletter-footer__error-{{ ai_gen_id }} {
    color: {{ block.settings.error_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-newsletter-footer__heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.85);
    }

    .ai-newsletter-footer__subtext-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.subtext_size }}px * 0.9);
    }
  }
{% endstyle %}

<newsletter-signup-{{ ai_gen_id }}
  class="ai-newsletter-footer-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  {%- if block.settings.heading != blank -%}
    <h3 class="ai-newsletter-footer__heading-{{ ai_gen_id }}">
      {{ block.settings.heading }}
    </h3>
  {%- endif -%}

  {%- if block.settings.subtext != blank -%}
    <p class="ai-newsletter-footer__subtext-{{ ai_gen_id }}">
      {{ block.settings.subtext }}
    </p>
  {%- endif -%}

  {%- form 'customer', class: 'ai-newsletter-footer__form-wrapper-' | append: ai_gen_id -%}
    <input type="hidden" name="contact[tags]" value="newsletter">
    
    <div class="ai-newsletter-footer__input-wrapper-{{ ai_gen_id }}">
      <input
        type="email"
        name="contact[email]"
        class="ai-newsletter-footer__input-{{ ai_gen_id }}"
        value="{{ form.email }}"
        placeholder="{{ block.settings.placeholder }}"
        aria-label="{{ block.settings.placeholder }}"
        autocorrect="off"
        autocapitalize="off"
        autocomplete="email"
        {% if form.errors %}
          aria-invalid="true"
          aria-describedby="ai-newsletter-footer-error-{{ ai_gen_id }}"
        {% endif %}
        {% if form.posted_successfully? %}
          aria-describedby="ai-newsletter-footer-success-{{ ai_gen_id }}"
        {% endif %}
        required
      >
      <button
        type="submit"
        class="ai-newsletter-footer__button-{{ ai_gen_id }}"
        aria-label="Subscribe to newsletter"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
          <path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
        </svg>
      </button>
    </div>

    {%- if form.posted_successfully? -%}
      <div
        id="ai-newsletter-footer-success-{{ ai_gen_id }}"
        class="ai-newsletter-footer__message-{{ ai_gen_id }} ai-newsletter-footer__success-{{ ai_gen_id }}"
      >
        {{ block.settings.success_message }}
      </div>
    {%- endif -%}

    {%- if form.errors -%}
      <div
        id="ai-newsletter-footer-error-{{ ai_gen_id }}"
        class="ai-newsletter-footer__message-{{ ai_gen_id }} ai-newsletter-footer__error-{{ ai_gen_id }}"
      >
        {{ form.errors.messages.email }}
      </div>
    {%- endif -%}
  {%- endform -%}
</newsletter-signup-{{ ai_gen_id }}>

<script>
  (function() {
    class NewsletterSignup{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        const form = this.querySelector('form');
        if (!form) return;

        form.addEventListener('submit', (e) => {
          const emailInput = form.querySelector('input[type="email"]');
          if (emailInput && !emailInput.value.trim()) {
            e.preventDefault();
          }
        });
      }
    }

    customElements.define('newsletter-signup-{{ ai_gen_id }}', NewsletterSignup{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Newsletter signup",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "JOIN THE CLUB."
    },
    {
      "type": "inline_richtext",
      "id": "subtext",
      "label": "Subtext",
      "default": "Join and enter to win a gift card worth €150"
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Email placeholder",
      "default": "Enter your email address"
    },
    {
      "type": "inline_richtext",
      "id": "success_message",
      "label": "Success message",
      "default": "Thanks for subscribing!"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "font_picker",
      "id": "heading_font",
      "label": "Heading font",
      "default": "montserrat_n4"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "letter_spacing",
      "label": "Letter spacing",
      "min": 0,
      "max": 5,
      "step": 0.5,
      "unit": "px",
      "default": 2
    },
    {
      "type": "range",
      "id": "heading_spacing",
      "label": "Heading bottom spacing",
      "min": 4,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "subtext_size",
      "label": "Subtext size",
      "min": 10,
      "max": 18,
      "step": 1,
      "unit": "px",
      "default": 13
    },
    {
      "type": "range",
      "id": "subtext_spacing",
      "label": "Subtext bottom spacing",
      "min": 8,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "input_size",
      "label": "Input size",
      "min": 10,
      "max": 18,
      "step": 1,
      "unit": "px",
      "default": 13
    },
    {
      "type": "range",
      "id": "input_padding",
      "label": "Input padding",
      "min": 6,
      "max": 16,
      "step": 1,
      "unit": "px",
      "default": 10
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon size",
      "min": 14,
      "max": 28,
      "step": 2,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "message_size",
      "label": "Message size",
      "min": 10,
      "max": 16,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#f5f1e8"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border color",
      "default": "#f5f1e8"
    },
    {
      "type": "color",
      "id": "border_focus_color",
      "label": "Border focus color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "border_width",
      "label": "Border width",
      "min": 1,
      "max": 3,
      "step": 1,
      "unit": "px",
      "default": 1
    },
    {
      "type": "color",
      "id": "success_color",
      "label": "Success color",
      "default": "#a8d5a8"
    },
    {
      "type": "color",
      "id": "error_color",
      "label": "Error color",
      "default": "#f5a3a3"
    }
  ],
  "presets": [
    {
      "name": "Newsletter signup"
    }
  ]
}
{% endschema %}