{% doc %}
  @prompt
    Create a compact email signup block designed for a footer. It should have a khaki/muted gold background, with a small spaced-out heading "WORD LID VAN DE CLUB.", a short line "Word lid en maak kans op een cadeaubon ter waarde van €150", and a minimal inline email input field with placeholder "Voer uw e-mailadres in" and an envelope submit icon on the right. Keep it compact and elegant — cream/light colored text on the gold background. Luxury streetwear aesthetic, minimal padding, footer-sized.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-footer-signup-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-footer-signup__container-{{ ai_gen_id }} {
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding_vertical }}px {{ block.settings.padding_horizontal }}px;
    text-align: center;
  }

  .ai-footer-signup__heading-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.heading_size }}px;
    letter-spacing: {{ block.settings.letter_spacing }}px;
    margin: 0 0 {{ block.settings.heading_spacing }}px 0;
    text-transform: uppercase;
    font-weight: 400;
  }

  .ai-footer-signup__subtext-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.subtext_size }}px;
    margin: 0 0 {{ block.settings.subtext_spacing }}px 0;
    opacity: 0.9;
  }

  .ai-footer-signup__form-wrapper-{{ ai_gen_id }} {
    max-width: {{ block.settings.form_max_width }}px;
    margin: 0 auto;
  }

  .ai-footer-signup__field-{{ ai_gen_id }} {
    position: relative;
    display: flex;
    align-items: center;
  }

  .ai-footer-signup__input-{{ ai_gen_id }} {
    flex-grow: 1;
    padding: {{ block.settings.input_padding }}px {{ block.settings.input_padding }}px {{ block.settings.input_padding }}px {{ block.settings.input_padding }}px;
    padding-right: 50px;
    border: 1px solid {{ block.settings.input_border_color }};
    background-color: {{ block.settings.input_background }};
    color: {{ block.settings.input_text_color }};
    font-size: {{ block.settings.input_font_size }}px;
    border-radius: {{ block.settings.input_border_radius }}px;
    width: 100%;
  }

  .ai-footer-signup__input-{{ ai_gen_id }}::placeholder {
    color: {{ block.settings.placeholder_color }};
    opacity: 0.7;
  }

  .ai-footer-signup__input-{{ ai_gen_id }}:focus {
    outline: 2px solid {{ block.settings.input_focus_color }};
    outline-offset: 2px;
  }

  .ai-footer-signup__button-{{ ai_gen_id }} {
    position: absolute;
    right: 8px;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    padding: 8px;
    cursor: pointer;
    color: {{ block.settings.button_icon_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.2s ease;
  }

  .ai-footer-signup__button-{{ ai_gen_id }}:hover {
    opacity: 0.7;
  }

  .ai-footer-signup__button-{{ ai_gen_id }} svg {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
  }

  .ai-footer-signup__message-{{ ai_gen_id }} {
    margin-top: 8px;
    font-size: 12px;
  }

  .ai-footer-signup__success-{{ ai_gen_id }} {
    color: {{ block.settings.success_color }};
  }

  .ai-footer-signup__error-{{ ai_gen_id }} {
    color: {{ block.settings.error_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-footer-signup__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.85 }}px;
    }

    .ai-footer-signup__subtext-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtext_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<footer-email-signup-{{ ai_gen_id }}
  class="ai-footer-signup-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-footer-signup__container-{{ ai_gen_id }}">
    {%- if block.settings.heading != blank -%}
      <h3 class="ai-footer-signup__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h3>
    {%- endif -%}

    {%- if block.settings.subtext != blank -%}
      <p class="ai-footer-signup__subtext-{{ ai_gen_id }}">{{ block.settings.subtext }}</p>
    {%- endif -%}

    {%- form 'customer', class: 'ai-footer-signup__form-wrapper-' | append: ai_gen_id -%}
      <input type="hidden" name="contact[tags]" value="newsletter">
      
      <div class="ai-footer-signup__field-{{ ai_gen_id }}">
        <input
          type="email"
          name="contact[email]"
          class="ai-footer-signup__input-{{ ai_gen_id }}"
          value="{{ form.email }}"
          aria-required="true"
          autocorrect="off"
          autocapitalize="off"
          autocomplete="email"
          {% if form.errors %}
            aria-invalid="true"
            aria-describedby="ai-footer-signup-error-{{ ai_gen_id }}"
          {% endif %}
          {% if form.posted_successfully? %}
            aria-describedby="ai-footer-signup-success-{{ ai_gen_id }}"
          {% endif %}
          placeholder="{{ block.settings.email_placeholder }}"
          required
        >
        <button
          type="submit"
          class="ai-footer-signup__button-{{ ai_gen_id }}"
          aria-label="Subscribe"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
            <polyline points="22,6 12,13 2,6"></polyline>
          </svg>
        </button>
      </div>

      {%- if form.errors -%}
        <div
          id="ai-footer-signup-error-{{ ai_gen_id }}"
          class="ai-footer-signup__message-{{ ai_gen_id }} ai-footer-signup__error-{{ ai_gen_id }}"
        >
          <span>{{ form.errors.messages.email }}</span>
        </div>
      {%- endif -%}

      {%- if form.posted_successfully? -%}
        <div
          id="ai-footer-signup-success-{{ ai_gen_id }}"
          class="ai-footer-signup__message-{{ ai_gen_id }} ai-footer-signup__success-{{ ai_gen_id }}"
        >
          <span>{{ block.settings.success_message }}</span>
        </div>
      {%- endif -%}
    {%- endform -%}
  </div>
</footer-email-signup-{{ ai_gen_id }}>

<script>
  (function() {
    class FooterEmailSignup{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.form = this.querySelector('form');
        if (this.form) {
          this.form.addEventListener('submit', this.handleSubmit.bind(this));
        }
      }

      handleSubmit(event) {
        const emailInput = this.form.querySelector('input[type="email"]');
        if (emailInput && !emailInput.value.trim()) {
          event.preventDefault();
        }
      }
    }

    customElements.define('footer-email-signup-{{ ai_gen_id }}', FooterEmailSignup{{ ai_gen_id }});
  })();
</script>

