{% doc %}
  @prompt
    Create a minimal static text section to be placed between a hero video and a slideshow on the homepage. It should display a short brand tagline centered on the page, with generous padding above and below. Clean, minimal, premium streetwear aesthetic. Dark or neutral background that complements a video above it. The text should be elegant and large, with an option to customize the tagline text in the theme editor.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-tagline-block-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
  }

  .ai-tagline-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    padding-left: 20px;
    padding-right: 20px;
    text-align: center;
  }

  .ai-tagline-text-{{ ai_gen_id }} {
    font-family: {{ block.settings.font_family.family }}, {{ block.settings.font_family.fallback_families }};
    font-weight: {{ block.settings.font_family.weight }};
    font-style: {{ block.settings.font_family.style }};
    font-size: {{ block.settings.font_size }}px;
    line-height: {{ block.settings.line_height }};
    color: {{ block.settings.text_color }};
    margin: 0;
    letter-spacing: {{ block.settings.letter_spacing }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-tagline-block-{{ ai_gen_id }} {
      padding-top: {{ block.settings.padding_top | times: 0.6 }}px;
      padding-bottom: {{ block.settings.padding_bottom | times: 0.6 }}px;
    }

    .ai-tagline-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size | times: 0.7 }}px;
    }
  }
{% endstyle %}

<tagline-block-{{ ai_gen_id }}
  class="ai-tagline-block-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-tagline-container-{{ ai_gen_id }}">
    {% if block.settings.tagline != blank %}
      <p class="ai-tagline-text-{{ ai_gen_id }}">{{ block.settings.tagline }}</p>
    {% else %}
      <p class="ai-tagline-text-{{ ai_gen_id }}" style="opacity: 0.5;">Add your tagline</p>
    {% endif %}
  </div>
</tagline-block-{{ ai_gen_id }}>

<script>
  (function() {
    class TaglineBlock{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }
    }
    customElements.define('tagline-block-{{ ai_gen_id }}', TaglineBlock{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Brand tagline",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "tagline",
      "label": "Tagline",
      "default": "Redefining streetwear"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 200,
      "step": 10,
      "unit": "px",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 200,
      "step": 10,
      "unit": "px",
      "default": 100
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Maximum width",
      "min": 400,
      "max": 1400,
      "step": 100,
      "unit": "px",
      "default": 900
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "font_picker",
      "id": "font_family",
      "label": "Font",
      "default": "montserrat_n4"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 20,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "line_height",
      "label": "Line height",
      "min": 1,
      "max": 2,
      "step": 0.1,
      "default": 1.2
    },
    {
      "type": "range",
      "id": "letter_spacing",
      "label": "Letter spacing",
      "min": 0,
      "max": 10,
      "step": 1,
      "unit": "px",
      "default": 2
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#0f0f0f"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Brand tagline"
    }
  ]
}
{% endschema %}