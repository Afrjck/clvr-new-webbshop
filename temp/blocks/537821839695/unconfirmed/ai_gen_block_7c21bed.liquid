{% doc %}
  @prompt
    Update the World Cup prediction widget (Marokko vs Brazilië) so that the duplicate submission check only blocks an email address if it has already submitted a prediction for this specific contest — not just because the email already exists as a Shopify customer. A person who is already a customer should be able to participate. The "Je hebt al meegedaan!" message should only appear if that exact email address has already submitted a prediction (i.e., already has the tag "mar-bra-2026" AND a stored prediction for this contest). Existing customers without a prior prediction should be allowed to submit normally.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-worldcup-widget-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    padding: 40px;
    background: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    font-family: {{ block.settings.font_family.family }}, sans-serif;
  }

  .ai-worldcup-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 30px;
  }

  .ai-worldcup-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 10px;
    font-weight: 700;
  }

  .ai-worldcup-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.text_color }};
    opacity: 0.8;
    margin: 0;
  }

  .ai-worldcup-match-{{ ai_gen_id }} {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 20px;
    margin-bottom: 30px;
    padding: 20px;
    background: {{ block.settings.match_bg_color }};
    border-radius: {{ block.settings.match_border_radius }}px;
  }

  .ai-worldcup-team-{{ ai_gen_id }} {
    flex: 1;
    text-align: center;
  }

  .ai-worldcup-flag-{{ ai_gen_id }} {
    width: 80px;
    height: 80px;
    margin: 0 auto 10px;
    border-radius: 50%;
    overflow: hidden;
    border: 3px solid {{ block.settings.flag_border_color }};
  }

  .ai-worldcup-flag-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-worldcup-team-name-{{ ai_gen_id }} {
    font-size: 18px;
    font-weight: 600;
    color: {{ block.settings.text_color }};
    margin: 0;
  }

  .ai-worldcup-vs-{{ ai_gen_id }} {
    font-size: 24px;
    font-weight: 700;
    color: {{ block.settings.text_color }};
    opacity: 0.5;
  }

  .ai-worldcup-form-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .ai-worldcup-input-group-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ai-worldcup-label-{{ ai_gen_id }} {
    font-size: 14px;
    font-weight: 600;
    color: {{ block.settings.text_color }};
  }

  .ai-worldcup-input-{{ ai_gen_id }} {
    padding: 12px 16px;
    border: 2px solid {{ block.settings.input_border_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    font-size: 16px;
    font-family: inherit;
    background: {{ block.settings.input_bg_color }};
    color: {{ block.settings.text_color }};
  }

  .ai-worldcup-input-{{ ai_gen_id }}:focus {
    outline: none;
    border-color: {{ block.settings.button_color }};
  }

  .ai-worldcup-score-inputs-{{ ai_gen_id }} {
    display: flex;
    gap: 15px;
    align-items: center;
  }

  .ai-worldcup-score-input-{{ ai_gen_id }} {
    flex: 1;
    text-align: center;
  }

  .ai-worldcup-score-separator-{{ ai_gen_id }} {
    font-size: 24px;
    font-weight: 700;
    color: {{ block.settings.text_color }};
    opacity: 0.5;
  }

  .ai-worldcup-submit-{{ ai_gen_id }} {
    padding: 16px 32px;
    background: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: 18px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .ai-worldcup-submit-{{ ai_gen_id }}:hover {
    background: {{ block.settings.button_hover_color }};
    transform: translateY(-2px);
  }

  .ai-worldcup-submit-{{ ai_gen_id }}:disabled {
    opacity: 0.5;
    cursor: not-allowed;
    transform: none;
  }

  .ai-worldcup-message-{{ ai_gen_id }} {
    padding: 16px;
    border-radius: {{ block.settings.input_border_radius }}px;
    text-align: center;
    font-weight: 600;
    margin-top: 20px;
  }

  .ai-worldcup-message-{{ ai_gen_id }}.success {
    background: {{ block.settings.success_bg_color }};
    color: {{ block.settings.success_text_color }};
  }

  .ai-worldcup-message-{{ ai_gen_id }}.error {
    background: {{ block.settings.error_bg_color }};
    color: {{ block.settings.error_text_color }};
  }

  .ai-worldcup-loading-{{ ai_gen_id }} {
    display: none;
    text-align: center;
    padding: 20px;
    color: {{ block.settings.text_color }};
  }

  .ai-worldcup-loading-{{ ai_gen_id }}.active {
    display: block;
  }

  @media screen and (max-width: 749px) {
    .ai-worldcup-widget-{{ ai_gen_id }} {
      padding: 20px;
    }

    .ai-worldcup-match-{{ ai_gen_id }} {
      flex-direction: column;
      gap: 15px;
    }

    .ai-worldcup-flag-{{ ai_gen_id }} {
      width: 60px;
      height: 60px;
    }

    .ai-worldcup-vs-{{ ai_gen_id }} {
      transform: rotate(90deg);
    }
  }
{% endstyle %}

<worldcup-prediction-{{ ai_gen_id }}
  class="ai-worldcup-widget-{{ ai_gen_id }}"
  data-contest-tag="{{ block.settings.contest_tag }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-worldcup-header-{{ ai_gen_id }}">
    <h2 class="ai-worldcup-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
    {% if block.settings.subtitle != blank %}
      <p class="ai-worldcup-subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</p>
    {% endif %}
  </div>

  <div class="ai-worldcup-match-{{ ai_gen_id }}">
    <div class="ai-worldcup-team-{{ ai_gen_id }}">
      <div class="ai-worldcup-flag-{{ ai_gen_id }}">
        {% if block.settings.team1_flag %}
          <img
            src="{{ block.settings.team1_flag | image_url: width: 160 }}"
            alt="{{ block.settings.team1_name }}"
            loading="lazy"
          >
        {% else %}
          <div style="width: 100%; height: 100%; background: #f0f0f0;"></div>
        {% endif %}
      </div>
      <p class="ai-worldcup-team-name-{{ ai_gen_id }}">{{ block.settings.team1_name }}</p>
    </div>

    <div class="ai-worldcup-vs-{{ ai_gen_id }}">VS</div>

    <div class="ai-worldcup-team-{{ ai_gen_id }}">
      <div class="ai-worldcup-flag-{{ ai_gen_id }}">
        {% if block.settings.team2_flag %}
          <img
            src="{{ block.settings.team2_flag | image_url: width: 160 }}"
            alt="{{ block.settings.team2_name }}"
            loading="lazy"
          >
        {% else %}
          <div style="width: 100%; height: 100%; background: #f0f0f0;"></div>
        {% endif %}
      </div>
      <p class="ai-worldcup-team-name-{{ ai_gen_id }}">{{ block.settings.team2_name }}</p>
    </div>
  </div>

  <form class="ai-worldcup-form-{{ ai_gen_id }}" data-prediction-form>
    <div class="ai-worldcup-input-group-{{ ai_gen_id }}">
      <label class="ai-worldcup-label-{{ ai_gen_id }}" for="email-{{ ai_gen_id }}">
        {{ block.settings.email_label }}
      </label>
      <input
        type="email"
        id="email-{{ ai_gen_id }}"
        name="email"
        class="ai-worldcup-input-{{ ai_gen_id }}"
        placeholder="{{ block.settings.email_placeholder }}"
        required
        autocomplete="email"
      >
    </div>

    <div class="ai-worldcup-input-group-{{ ai_gen_id }}">
      <label class="ai-worldcup-label-{{ ai_gen_id }}">
        {{ block.settings.score_label }}
      </label>
      <div class="ai-worldcup-score-inputs-{{ ai_gen_id }}">
        <input
          type="number"
          name="team1_score"
          class="ai-worldcup-input-{{ ai_gen_id }} ai-worldcup-score-input-{{ ai_gen_id }}"
          placeholder="0"
          min="0"
          max="20"
          required
        >
        <span class="ai-worldcup-score-separator-{{ ai_gen_id }}">-</span>
        <input
          type="number"
          name="team2_score"
          class="ai-worldcup-input-{{ ai_gen_id }} ai-worldcup-score-input-{{ ai_gen_id }}"
          placeholder="0"
          min="0"
          max="20"
          required
        >
      </div>
    </div>

    <button type="submit" class="ai-worldcup-submit-{{ ai_gen_id }}">
      {{ block.settings.submit_text }}
    </button>
  </form>

  <div class="ai-worldcup-loading-{{ ai_gen_id }}" data-loading>
    Bezig met verwerken...
  </div>

  <div class="ai-worldcup-message-{{ ai_gen_id }}" data-message style="display: none;"></div>
</worldcup-prediction-{{ ai_gen_id }}>

<script>
  (function() {
    class WorldCupPrediction{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.form = this.querySelector('[data-prediction-form]');
        this.loading = this.querySelector('[data-loading]');
        this.message = this.querySelector('[data-message]');
        this.contestTag = this.dataset.contestTag;
      }

      connectedCallback() {
        this.form.addEventListener('submit', this.handleSubmit.bind(this));
      }

      async handleSubmit(e) {
        e.preventDefault();

        const formData = new FormData(this.form);
        const email = formData.get('email');
        const team1Score = formData.get('team1_score');
        const team2Score = formData.get('team2_score');

        this.showLoading();

        try {
          const isDuplicate = await this.checkDuplicateSubmission(email);

          if (isDuplicate) {
            this.showMessage('Je hebt al meegedaan!', 'error');
            return;
          }

          await this.submitPrediction(email, team1Score, team2Score);
          this.showMessage('{{ block.settings.success_message }}', 'success');
          this.form.reset();
        } catch (error) {
          this.showMessage('{{ block.settings.error_message }}', 'error');
        } finally {
          this.hideLoading();
        }
      }

      async checkDuplicateSubmission(email) {
        try {
          const response = await fetch(`/admin/api/2024-01/customers/search.json?query=email:${encodeURIComponent(email)}`, {
            method: 'GET',
            headers: {
              'Content-Type': 'application/json',
            }
          });

          if (!response.ok) {
            const searchResponse = await fetch(`/search/suggest.json?q=${encodeURIComponent(email)}&resources[type]=customer`);
            
            if (searchResponse.ok) {
              const data = await searchResponse.json();
              if (data.resources && data.resources.results && data.resources.results.customers) {
                const customers = data.resources.results.customers;
                const matchingCustomer = customers.find(c => c.email && c.email.toLowerCase() === email.toLowerCase());
                
                if (matchingCustomer) {
                  const hasContestTag = matchingCustomer.tags && matchingCustomer.tags.includes(this.contestTag);
                  const hasPredictionNote = matchingCustomer.note && matchingCustomer.note.includes(`${this.contestTag}:`);
                  
                  return hasContestTag && hasPredictionNote;
                }
              }
            }
            return false;
          }

          const data = await response.json();
          
          if (data.customers && data.customers.length > 0) {
            const customer = data.customers[0];
            const hasContestTag = customer.tags && customer.tags.includes(this.contestTag);
            const hasPredictionNote = customer.note && customer.note.includes(`${this.contestTag}:`);
            
            return hasContestTag && hasPredictionNote;
          }

          return false;
        } catch (error) {
          return false;
        }
      }

      async submitPrediction(email, team1Score, team2Score) {
        const predictionData = `${this.contestTag}: ${team1Score}-${team2Score}`;
        
        const response = await fetch('/contact', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
          },
          body: new URLSearchParams({
            'form_type': 'customer',
            'utf8': '✓',
            'contact[email]': email,
            'contact[tags]': this.contestTag,
            'contact[note]': predictionData,
            'contact[prediction]': `${team1Score}-${team2Score}`,
            'contact[contest]': this.contestTag
          })
        });

        if (!response.ok) {
          throw new Error('Submission failed');
        }

        return response;
      }

      showLoading() {
        this.loading.classList.add('active');
        this.form.querySelector('button[type="submit"]').disabled = true;
        this.message.style.display = 'none';
      }

      hideLoading() {
        this.loading.classList.remove('active');
        this.form.querySelector('button[type="submit"]').disabled = false;
      }

      showMessage(text, type) {
        this.message.textContent = text;
        this.message.className = `ai-worldcup-message-{{ ai_gen_id }} ${type}`;
        this.message.style.display = 'block';
      }
    }

    customElements.define('worldcup-prediction-{{ ai_gen_id }}', WorldCupPrediction{{ ai_gen_id }});
  })();
</script>

