{% doc %}
  @prompt
    Create a World Cup prediction widget section for a Shopify page. The widget should:
    
    - Show a contest banner: "Marokko vs Brazilië — 14 juni 2026" with a live countdown timer that counts down to June 14, 2026 at 20:00 Amsterdam time (CEST). After the deadline, show "Inzending gesloten" and hide the form.
    - Show a scarcity notification: "Nog ~20 shirts beschikbaar" as a subtle badge/tag
    - A form with:
      - Email field (required, label: "Jouw e-mailadres")
      - Score prediction: two number inputs side by side labeled "Marokko" and "Brazilië" (min 0, integers only)
      - Optional text field: "Doelpuntenmakers (optioneel)" with placeholder "Bijv. Hakimi, En-Nesyri, Vinicius — komma-gescheiden"
      - Submit button: "Doe mee"
    - After submit, show a success message: "Jouw voorspelling is opgeslagen! Je hoort van ons als je gewonnen hebt."
    - Prizes explanation section below the form:
      - "🎯 Juiste score → €20 korting"
      - "🏆 Juiste score + doelpuntenmaker → Gratis shirt"
    - On submit, the form data should be saved as a Shopify customer (create customer with email if not exists, add tags: "wk-voorspelling", "mar-bra-2026") and store the prediction in a customer note or metafield
    - One submission per email — if email already submitted, show: "Je hebt al meegedaan!"
    - Deadline: June 14, 2026 at 20:00 CEST (18:00 UTC) — after this, form is hidden and replaced with "De inzending is gesloten."
    - Dark, premium streetwear aesthetic: dark background (#0a0a0a), white text, minimal typography, gold accent color (#c9a84c) for highlights
    - All text in Dutch
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-wk-widget-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    padding: 40px;
    color: {{ block.settings.text_color }};
  }

  .ai-wk-widget__banner-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 24px;
  }

  .ai-wk-widget__match-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: 700;
    margin: 0 0 12px;
    color: {{ block.settings.text_color }};
    letter-spacing: 0.5px;
  }

  .ai-wk-widget__countdown-{{ ai_gen_id }} {
    font-size: 18px;
    color: {{ block.settings.accent_color }};
    font-weight: 600;
    margin-bottom: 16px;
  }

  .ai-wk-widget__scarcity-{{ ai_gen_id }} {
    display: inline-block;
    background-color: {{ block.settings.accent_color }};
    color: {{ block.settings.background_color }};
    padding: 6px 16px;
    border-radius: 20px;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.3px;
  }

  .ai-wk-widget__form-{{ ai_gen_id }} {
    margin-top: 32px;
  }

  .ai-wk-widget__field-{{ ai_gen_id }} {
    margin-bottom: 20px;
  }

  .ai-wk-widget__label-{{ ai_gen_id }} {
    display: block;
    font-size: 14px;
    font-weight: 600;
    margin-bottom: 8px;
    color: {{ block.settings.text_color }};
  }

  .ai-wk-widget__input-{{ ai_gen_id }} {
    width: 100%;
    padding: 12px 16px;
    background-color: {{ block.settings.input_bg_color }};
    border: 1px solid {{ block.settings.input_border_color }};
    border-radius: 6px;
    color: {{ block.settings.text_color }};
    font-size: 15px;
  }

  .ai-wk-widget__input-{{ ai_gen_id }}:focus {
    outline: none;
    border-color: {{ block.settings.accent_color }};
  }

  .ai-wk-widget__score-row-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .ai-wk-widget__score-field-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
  }

  .ai-wk-widget__score-input-{{ ai_gen_id }} {
    padding: 12px 16px;
    background-color: {{ block.settings.input_bg_color }};
    border: 1px solid {{ block.settings.input_border_color }};
    border-radius: 6px;
    color: {{ block.settings.text_color }};
    font-size: 18px;
    font-weight: 700;
    text-align: center;
  }

  .ai-wk-widget__score-input-{{ ai_gen_id }}:focus {
    outline: none;
    border-color: {{ block.settings.accent_color }};
  }

  .ai-wk-widget__submit-{{ ai_gen_id }} {
    width: 100%;
    padding: 16px 32px;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: 6px;
    font-size: 16px;
    font-weight: 700;
    cursor: pointer;
    transition: background-color 0.3s ease;
    margin-top: 8px;
  }

  .ai-wk-widget__submit-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  .ai-wk-widget__submit-{{ ai_gen_id }}:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .ai-wk-widget__prizes-{{ ai_gen_id }} {
    margin-top: 32px;
    padding-top: 24px;
    border-top: 1px solid {{ block.settings.input_border_color }};
  }

  .ai-wk-widget__prizes-title-{{ ai_gen_id }} {
    font-size: 16px;
    font-weight: 700;
    margin-bottom: 12px;
    color: {{ block.settings.text_color }};
  }

  .ai-wk-widget__prize-item-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 10px;
    font-size: 14px;
    color: {{ block.settings.text_color }};
  }

  .ai-wk-widget__prize-icon-{{ ai_gen_id }} {
    font-size: 20px;
  }

  .ai-wk-widget__message-{{ ai_gen_id }} {
    padding: 16px;
    border-radius: 6px;
    margin-top: 16px;
    font-size: 15px;
    text-align: center;
  }

  .ai-wk-widget__message--success-{{ ai_gen_id }} {
    background-color: rgba(34, 197, 94, 0.15);
    color: #22c55e;
    border: 1px solid rgba(34, 197, 94, 0.3);
  }

  .ai-wk-widget__message--error-{{ ai_gen_id }} {
    background-color: rgba(239, 68, 68, 0.15);
    color: #ef4444;
    border: 1px solid rgba(239, 68, 68, 0.3);
  }

  .ai-wk-widget__message--info-{{ ai_gen_id }} {
    background-color: rgba(201, 168, 76, 0.15);
    color: {{ block.settings.accent_color }};
    border: 1px solid rgba(201, 168, 76, 0.3);
  }

  .ai-wk-widget__closed-{{ ai_gen_id }} {
    text-align: center;
    padding: 40px 20px;
    font-size: 20px;
    font-weight: 600;
    color: {{ block.settings.text_color }};
  }

  .ai-wk-widget__hidden-{{ ai_gen_id }} {
    display: none;
  }

  @media screen and (max-width: 749px) {
    .ai-wk-widget-{{ ai_gen_id }} {
      padding: 24px;
    }

    .ai-wk-widget__match-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.8 }}px;
    }

    .ai-wk-widget__countdown-{{ ai_gen_id }} {
      font-size: 16px;
    }
  }
{% endstyle %}

<wk-prediction-widget-{{ ai_gen_id }}
  class="ai-wk-widget-{{ ai_gen_id }}"
  data-deadline="2026-06-14T18:00:00Z"
  {{ block.shopify_attributes }}
>
  <div class="ai-wk-widget__banner-{{ ai_gen_id }}">
    <h2 class="ai-wk-widget__match-title-{{ ai_gen_id }}">{{ block.settings.match_title }}</h2>
    <div class="ai-wk-widget__countdown-{{ ai_gen_id }}" data-countdown></div>
    <div class="ai-wk-widget__scarcity-{{ ai_gen_id }}">{{ block.settings.scarcity_text }}</div>
  </div>

  <div class="ai-wk-widget__form-container-{{ ai_gen_id }}" data-form-container>
    {%- form 'contact', id: 'wk-prediction-form', class: 'ai-wk-widget__form-' | append: ai_gen_id -%}
      <input type="hidden" name="contact[tags]" value="wk-voorspelling,mar-bra-2026">
      <input type="hidden" name="contact[note]" value="" data-prediction-note>

      <div class="ai-wk-widget__field-{{ ai_gen_id }}">
        <label for="wk-email-{{ ai_gen_id }}" class="ai-wk-widget__label-{{ ai_gen_id }}">
          {{ block.settings.email_label }}
        </label>
        <input
          type="email"
          id="wk-email-{{ ai_gen_id }}"
          name="contact[email]"
          class="ai-wk-widget__input-{{ ai_gen_id }}"
          required
          autocomplete="email"
          data-email-input
        >
      </div>

      <div class="ai-wk-widget__field-{{ ai_gen_id }}">
        <label class="ai-wk-widget__label-{{ ai_gen_id }}">{{ block.settings.score_label }}</label>
        <div class="ai-wk-widget__score-row-{{ ai_gen_id }}">
          <div class="ai-wk-widget__score-field-{{ ai_gen_id }}">
            <label for="score-morocco-{{ ai_gen_id }}" class="ai-wk-widget__label-{{ ai_gen_id }}">
              {{ block.settings.team_1_name }}
            </label>
            <input
              type="number"
              id="score-morocco-{{ ai_gen_id }}"
              class="ai-wk-widget__score-input-{{ ai_gen_id }}"
              min="0"
              step="1"
              required
              data-score-morocco
            >
          </div>
          <div class="ai-wk-widget__score-field-{{ ai_gen_id }}">
            <label for="score-brazil-{{ ai_gen_id }}" class="ai-wk-widget__label-{{ ai_gen_id }}">
              {{ block.settings.team_2_name }}
            </label>
            <input
              type="number"
              id="score-brazil-{{ ai_gen_id }}"
              class="ai-wk-widget__score-input-{{ ai_gen_id }}"
              min="0"
              step="1"
              required
              data-score-brazil
            >
          </div>
        </div>
      </div>

      <div class="ai-wk-widget__field-{{ ai_gen_id }}">
        <label for="scorers-{{ ai_gen_id }}" class="ai-wk-widget__label-{{ ai_gen_id }}">
          {{ block.settings.scorers_label }}
        </label>
        <input
          type="text"
          id="scorers-{{ ai_gen_id }}"
          class="ai-wk-widget__input-{{ ai_gen_id }}"
          placeholder="{{ block.settings.scorers_placeholder }}"
          data-scorers-input
        >
      </div>

      <button
        type="submit"
        class="ai-wk-widget__submit-{{ ai_gen_id }}"
        data-submit-button
      >
        {{ block.settings.submit_text }}
      </button>
    {%- endform -%}

    <div class="ai-wk-widget__message-{{ ai_gen_id }} ai-wk-widget__hidden-{{ ai_gen_id }}" data-message></div>
  </div>

  <div class="ai-wk-widget__closed-{{ ai_gen_id }} ai-wk-widget__hidden-{{ ai_gen_id }}" data-closed-message>
    {{ block.settings.closed_text }}
  </div>

  <div class="ai-wk-widget__prizes-{{ ai_gen_id }}">
    <div class="ai-wk-widget__prizes-title-{{ ai_gen_id }}">{{ block.settings.prizes_title }}</div>
    <div class="ai-wk-widget__prize-item-{{ ai_gen_id }}">
      <span class="ai-wk-widget__prize-icon-{{ ai_gen_id }}">🎯</span>
      <span>{{ block.settings.prize_1_text }}</span>
    </div>
    <div class="ai-wk-widget__prize-item-{{ ai_gen_id }}">
      <span class="ai-wk-widget__prize-icon-{{ ai_gen_id }}">🏆</span>
      <span>{{ block.settings.prize_2_text }}</span>
    </div>
  </div>
</wk-prediction-widget-{{ ai_gen_id }}>

<script>
  (function() {
    class WKPredictionWidget{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.deadline = new Date(this.dataset.deadline);
        this.countdownEl = this.querySelector('[data-countdown]');
        this.formContainer = this.querySelector('[data-form-container]');
        this.closedMessage = this.querySelector('[data-closed-message]');
        this.form = this.querySelector('form');
        this.messageEl = this.querySelector('[data-message]');
        this.submitButton = this.querySelector('[data-submit-button]');
        this.emailInput = this.querySelector('[data-email-input]');
        this.submittedEmails = this.getSubmittedEmails();
      }

      connectedCallback() {
        this.updateCountdown();
        this.countdownInterval = setInterval(() => this.updateCountdown(), 1000);
        
        if (this.form) {
          this.form.addEventListener('submit', (e) => this.handleSubmit(e));
          this.emailInput.addEventListener('blur', () => this.checkEmailSubmitted());
        }
      }

      disconnectedCallback() {
        if (this.countdownInterval) {
          clearInterval(this.countdownInterval);
        }
      }

      updateCountdown() {
        const now = new Date();
        const diff = this.deadline - now;

        if (diff <= 0) {
          this.showClosedState();
          return;
        }

        const days = Math.floor(diff / (1000 * 60 * 60 * 24));
        const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
        const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
        const seconds = Math.floor((diff % (1000 * 60)) / 1000);

        let countdownText = '';
        if (days > 0) {
          countdownText = days + 'd ' + hours + 'u ' + minutes + 'm';
        } else if (hours > 0) {
          countdownText = hours + 'u ' + minutes + 'm ' + seconds + 's';
        } else {
          countdownText = minutes + 'm ' + seconds + 's';
        }

        this.countdownEl.textContent = countdownText;
      }

      showClosedState() {
        if (this.countdownInterval) {
          clearInterval(this.countdownInterval);
        }
        this.countdownEl.textContent = 'Inzending gesloten';
        this.formContainer.classList.add('ai-wk-widget__hidden-{{ ai_gen_id }}');
        this.closedMessage.classList.remove('ai-wk-widget__hidden-{{ ai_gen_id }}');
      }

      getSubmittedEmails() {
        try {
          const stored = localStorage.getItem('wk_predictions_{{ ai_gen_id }}');
          return stored ? JSON.parse(stored) : [];
        } catch (e) {
          return [];
        }
      }

      saveSubmittedEmail(email) {
        try {
          this.submittedEmails.push(email.toLowerCase());
          localStorage.setItem('wk_predictions_{{ ai_gen_id }}', JSON.stringify(this.submittedEmails));
        } catch (e) {
          console.error('Could not save to localStorage');
        }
      }

      checkEmailSubmitted() {
        const email = this.emailInput.value.toLowerCase().trim();
        if (email && this.submittedEmails.includes(email)) {
          this.showMessage('Je hebt al meegedaan!', 'info');
          this.submitButton.disabled = true;
          return true;
        } else {
          this.submitButton.disabled = false;
          this.hideMessage();
          return false;
        }
      }

      handleSubmit(e) {
        e.preventDefault();

        if (new Date() >= this.deadline) {
          this.showMessage('De inzending is gesloten.', 'error');
          return;
        }

        if (this.checkEmailSubmitted()) {
          return;
        }

        const formData = new FormData(this.form);
        const morocco = this.querySelector('[data-score-morocco]').value;
        const brazil = this.querySelector('[data-score-brazil]').value;
        const scorers = this.querySelector('[data-scorers-input]').value;

        const predictionNote = 'WK Voorspelling: Marokko ' + morocco + ' - ' + brazil + ' Brazilië';
        const fullNote = scorers ? predictionNote + ' | Doelpuntenmakers: ' + scorers : predictionNote;
        
        this.querySelector('[data-prediction-note]').value = fullNote;

        this.submitButton.disabled = true;
        this.submitButton.textContent = 'Bezig...';

        fetch(this.form.action, {
          method: 'POST',
          body: new FormData(this.form),
          headers: {
            'Accept': 'application/json'
          }
        })
        .then(response => {
          if (response.ok) {
            this.saveSubmittedEmail(this.emailInput.value);
            this.showMessage('Jouw voorspelling is opgeslagen! Je hoort van ons als je gewonnen hebt.', 'success');
            this.form.reset();
          } else {
            this.showMessage('Er is iets misgegaan. Probeer het opnieuw.', 'error');
          }
        })
        .catch(() => {
          this.showMessage('Er is iets misgegaan. Probeer het opnieuw.', 'error');
        })
        .finally(() => {
          this.submitButton.disabled = false;
          this.submitButton.textContent = '{{ block.settings.submit_text }}';
        });
      }

      showMessage(text, type) {
        this.messageEl.textContent = text;
        this.messageEl.className = 'ai-wk-widget__message-{{ ai_gen_id }} ai-wk-widget__message--' + type + '-{{ ai_gen_id }}';
        this.messageEl.classList.remove('ai-wk-widget__hidden-{{ ai_gen_id }}');
      }

      hideMessage() {
        this.messageEl.classList.add('ai-wk-widget__hidden-{{ ai_gen_id }}');
      }
    }

    customElements.define('wk-prediction-widget-{{ ai_gen_id }}', WKPredictionWidget{{ ai_gen_id }});
  })();
</script>

