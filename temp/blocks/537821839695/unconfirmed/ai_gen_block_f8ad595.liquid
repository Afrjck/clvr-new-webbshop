      "min": 400,
      "max": 800,
      "step": 50,
      "unit": "px",
      "default": 600
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Titel grootte",
      "min": 20,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "header",
      "content": "Kleuren"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Achtergrond kleur",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Tekst kleur",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent kleur (goud)",
      "default": "#c9a84c"
    },
    {
      "type": "color",
      "id": "input_bg_color",
      "label": "Input achtergrond",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "input_border_color",
      "label": "Input border kleur",
      "default": "#333333"
    }
  ],
  "presets": [
    {
      "name": "WK voorspelling widget"
    }
  ]
