{% doc %}
  @prompt
    Create a World Cup prediction widget section for a Shopify page with a dark premium streetwear aesthetic.
    
    DESIGN:
    - Dark background #000000, white text, gold accent #c9a84c
    - Minimal, editorial typography
    - Clean form inputs with dark styling
    - Gold submit button
    
    CONTENT:
    - Header: "Marokko vs Brazilië — 14 juni 2026"
    - Live countdown to June 14 2026 20:00 CEST (18:00 UTC)
    - Scarcity badge: "Nog ~20 shirts beschikbaar" in gold
    - Form fields: email (required), two side-by-side number inputs for Marokko and Brazilië scores, optional text field for doelpuntenmakers (komma-gescheiden)
    - Submit button: "Doe mee"
    - Success message: "Jouw voorspelling is opgeslagen! Je hoort van ons als je gewonnen hebt."
    - Prizes: "🎯 Juiste score → €20 korting" and "🏆 Juiste score + doelpuntenmaker → Gratis shirt"
    
    FUNCTIONALITY:
    - After deadline (June 14 2026 20:00 CEST): hide form, show "De inzending is gesloten."
    - On submit: save customer with email, add tags "wk-voorspelling" and "mar-bra-2026", store prediction in customer note or metafield
    - DUPLICATE CHECK: only show "Je hebt al meegedaan!" if the email has ALREADY submitted a prediction for this contest (has tag mar-bra-2026 AND stored prediction). Do NOT block existing customers who have not yet submitted a prediction.
    - All text in Dutch
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-wc-widget-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: 60px 40px;
  }

  .ai-wc-widget__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    width: {{ block.settings.desktop_width_percent }}%;
  }

  .ai-wc-widget__header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 40px;
  }

  .ai-wc-widget__title-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.title_size }}px;
    margin: 0 0 20px;
    font-weight: 600;
    letter-spacing: -0.02em;
  }

  .ai-wc-widget__countdown-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: 20px;
    margin-bottom: 20px;
  }

  .ai-wc-widget__countdown-item-{{ ai_gen_id }} {
    text-align: center;
  }

  .ai-wc-widget__countdown-value-{{ ai_gen_id }} {
    color: {{ block.settings.accent_color }};
    font-size: 32px;
    font-weight: 700;
    display: block;
    line-height: 1;
  }

  .ai-wc-widget__countdown-label-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-top: 8px;
    display: block;
    opacity: 0.7;
  }

  .ai-wc-widget__badge-{{ ai_gen_id }} {
    display: inline-block;
    background-color: {{ block.settings.accent_color }};
    color: {{ block.settings.background_color }};
    padding: 8px 16px;
    border-radius: 4px;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  .ai-wc-widget__form-{{ ai_gen_id }} {
    margin-top: 40px;
  }

  .ai-wc-widget__field-{{ ai_gen_id }} {
    margin-bottom: 20px;
  }

  .ai-wc-widget__label-{{ ai_gen_id }} {
    display: block;
    color: {{ block.settings.text_color }};
    font-size: 14px;
    margin-bottom: 8px;
    font-weight: 500;
  }

  .ai-wc-widget__input-{{ ai_gen_id }} {
    width: 100%;
    padding: 14px 16px;
    background-color: {{ block.settings.input_bg_color }};
    border: 1px solid {{ block.settings.input_border_color }};
    color: {{ block.settings.text_color }};
    font-size: 16px;
    border-radius: 4px;
    transition: border-color 0.2s ease;
  }

  .ai-wc-widget__input-{{ ai_gen_id }}:focus {
    outline: none;
    border-color: {{ block.settings.accent_color }};
  }

  .ai-wc-widget__input-{{ ai_gen_id }}::placeholder {
    color: {{ block.settings.text_color }};
    opacity: 0.5;
  }

  .ai-wc-widget__score-row-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .ai-wc-widget__score-field-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
  }

  .ai-wc-widget__input--number-{{ ai_gen_id }} {
    text-align: center;
    font-weight: 600;
    font-size: 18px;
  }

  .ai-wc-widget__button-{{ ai_gen_id }} {
    width: 100%;
    padding: 16px 32px;
    background-color: {{ block.settings.accent_color }};
    color: {{ block.settings.background_color }};
    border: none;
    border-radius: 4px;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    transition: opacity 0.2s ease;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .ai-wc-widget__button-{{ ai_gen_id }}:hover {
    opacity: 0.9;
  }

  .ai-wc-widget__button-{{ ai_gen_id }}:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .ai-wc-widget__message-{{ ai_gen_id }} {
    margin-top: 20px;
    padding: 16px;
    border-radius: 4px;
    text-align: center;
    font-size: 14px;
  }

  .ai-wc-widget__message--success-{{ ai_gen_id }} {
    background-color: rgba(201, 168, 76, 0.1);
    color: {{ block.settings.accent_color }};
    border: 1px solid {{ block.settings.accent_color }};
  }

  .ai-wc-widget__message--error-{{ ai_gen_id }} {
    background-color: rgba(255, 0, 0, 0.1);
    color: #ff4444;
    border: 1px solid #ff4444;
  }

  .ai-wc-widget__message--info-{{ ai_gen_id }} {
    background-color: rgba(255, 255, 255, 0.05);
    color: {{ block.settings.text_color }};
    border: 1px solid {{ block.settings.input_border_color }};
  }

  .ai-wc-widget__prizes-{{ ai_gen_id }} {
    margin-top: 40px;
    padding-top: 30px;
    border-top: 1px solid {{ block.settings.input_border_color }};
  }

  .ai-wc-widget__prize-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: 14px;
    margin-bottom: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }

  .ai-wc-widget__closed-{{ ai_gen_id }} {
    text-align: center;
    padding: 40px 20px;
  }

  .ai-wc-widget__closed-text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: 18px;
    opacity: 0.7;
  }

  @media screen and (max-width: 749px) {
    .ai-wc-widget-{{ ai_gen_id }} {
      padding: 40px 20px;
    }

    .ai-wc-widget__container-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-wc-widget__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.7 }}px;
    }

    .ai-wc-widget__countdown-value-{{ ai_gen_id }} {
      font-size: 24px;
    }

    .ai-wc-widget__countdown-{{ ai_gen_id }} {
      gap: 12px;
    }
  }
{% endstyle %}

<wc-prediction-widget-{{ ai_gen_id }}
  class="ai-wc-widget-{{ ai_gen_id }}"
  data-deadline="{{ block.settings.deadline_datetime }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-wc-widget__container-{{ ai_gen_id }}">
    <div class="ai-wc-widget__header-{{ ai_gen_id }}">
      <h2 class="ai-wc-widget__title-{{ ai_gen_id }}">{{ block.settings.match_title }}</h2>
      
      <div class="ai-wc-widget__countdown-{{ ai_gen_id }}" data-countdown>
        <div class="ai-wc-widget__countdown-item-{{ ai_gen_id }}">
          <span class="ai-wc-widget__countdown-value-{{ ai_gen_id }}" data-days>00</span>
          <span class="ai-wc-widget__countdown-label-{{ ai_gen_id }}">Dagen</span>
        </div>
        <div class="ai-wc-widget__countdown-item-{{ ai_gen_id }}">
          <span class="ai-wc-widget__countdown-value-{{ ai_gen_id }}" data-hours>00</span>
          <span class="ai-wc-widget__countdown-label-{{ ai_gen_id }}">Uren</span>
        </div>
        <div class="ai-wc-widget__countdown-item-{{ ai_gen_id }}">
          <span class="ai-wc-widget__countdown-value-{{ ai_gen_id }}" data-minutes>00</span>
          <span class="ai-wc-widget__countdown-label-{{ ai_gen_id }}">Min</span>
        </div>
        <div class="ai-wc-widget__countdown-item-{{ ai_gen_id }}">
          <span class="ai-wc-widget__countdown-value-{{ ai_gen_id }}" data-seconds>00</span>
          <span class="ai-wc-widget__countdown-label-{{ ai_gen_id }}">Sec</span>
        </div>
      </div>

      <div class="ai-wc-widget__badge-{{ ai_gen_id }}">{{ block.settings.scarcity_text }}</div>
    </div>

    <div data-form-container>
      {%- form 'contact' -%}
        <input type="hidden" name="contact[tags]" value="wk-voorspelling,{{ block.settings.contest_tag }}">
        
        <div class="ai-wc-widget__form-{{ ai_gen_id }}">
          <div class="ai-wc-widget__field-{{ ai_gen_id }}">
            <label class="ai-wc-widget__label-{{ ai_gen_id }}" for="email-{{ ai_gen_id }}">
              E-mailadres *
            </label>
            <input
              type="email"
              id="email-{{ ai_gen_id }}"
              name="contact[email]"
              class="ai-wc-widget__input-{{ ai_gen_id }}"
              placeholder="jouw@email.nl"
              required
              aria-required="true"
              {% if form.errors %}
                aria-invalid="true"
                aria-describedby="error-{{ ai_gen_id }}"
              {% endif %}
            >
          </div>

          <div class="ai-wc-widget__field-{{ ai_gen_id }}">
            <label class="ai-wc-widget__label-{{ ai_gen_id }}">
              Voorspel de eindstand *
            </label>
            <div class="ai-wc-widget__score-row-{{ ai_gen_id }}">
              <div class="ai-wc-widget__score-field-{{ ai_gen_id }}">
                <label class="ai-wc-widget__label-{{ ai_gen_id }}" for="score-team1-{{ ai_gen_id }}">
                  {{ block.settings.team1_name }}
                </label>
                <input
                  type="number"
                  id="score-team1-{{ ai_gen_id }}"
                  name="contact[score_team1]"
                  class="ai-wc-widget__input-{{ ai_gen_id }} ai-wc-widget__input--number-{{ ai_gen_id }}"
                  min="0"
                  max="20"
                  placeholder="0"
                  required
                  aria-required="true"
                >
              </div>
              <div class="ai-wc-widget__score-field-{{ ai_gen_id }}">
                <label class="ai-wc-widget__label-{{ ai_gen_id }}" for="score-team2-{{ ai_gen_id }}">
                  {{ block.settings.team2_name }}
                </label>
                <input
                  type="number"
                  id="score-team2-{{ ai_gen_id }}"
                  name="contact[score_team2]"
                  class="ai-wc-widget__input-{{ ai_gen_id }} ai-wc-widget__input--number-{{ ai_gen_id }}"
                  min="0"
                  max="20"
                  placeholder="0"
                  required
                  aria-required="true"
                >
              </div>
            </div>
          </div>

          <div class="ai-wc-widget__field-{{ ai_gen_id }}">
            <label class="ai-wc-widget__label-{{ ai_gen_id }}" for="scorers-{{ ai_gen_id }}">
              Doelpuntenmakers (optioneel, komma-gescheiden)
            </label>
            <input
              type="text"
              id="scorers-{{ ai_gen_id }}"
              name="contact[scorers]"
              class="ai-wc-widget__input-{{ ai_gen_id }}"
              placeholder="Bijv: Ziyech, Neymar"
            >
          </div>

          <button
            type="submit"
            class="ai-wc-widget__button-{{ ai_gen_id }}"
            data-submit-button
          >
            {{ block.settings.submit_text }}
          </button>

          {%- if form.errors -%}
            <div
              id="error-{{ ai_gen_id }}"
              class="ai-wc-widget__message-{{ ai_gen_id }} ai-wc-widget__message--error-{{ ai_gen_id }}"
            >
              {{ form.errors.messages.email }}
            </div>
          {%- endif -%}

          {%- if form.posted_successfully? -%}
            <div class="ai-wc-widget__message-{{ ai_gen_id }} ai-wc-widget__message--success-{{ ai_gen_id }}">
              {{ block.settings.success_message }}
            </div>
          {%- endif -%}

          <div class="ai-wc-widget__prizes-{{ ai_gen_id }}">
            <div class="ai-wc-widget__prize-{{ ai_gen_id }}">
              🎯 {{ block.settings.prize_1_text }}
            </div>
            <div class="ai-wc-widget__prize-{{ ai_gen_id }}">
              🏆 {{ block.settings.prize_2_text }}
            </div>
          </div>
        </div>
      {%- endform -%}
    </div>

    <div data-closed-message style="display: none;">
      <div class="ai-wc-widget__closed-{{ ai_gen_id }}">
        <p class="ai-wc-widget__closed-text-{{ ai_gen_id }}">{{ block.settings.closed_message }}</p>
      </div>
    </div>
  </div>
</wc-prediction-widget-{{ ai_gen_id }}>

<script>
  (function() {
    class WcPredictionWidget{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.deadlineStr = this.dataset.deadline;
        this.countdownEl = this.querySelector('[data-countdown]');
        this.formContainer = this.querySelector('[data-form-container]');
        this.closedMessage = this.querySelector('[data-closed-message]');
        this.interval = null;
      }

      connectedCallback() {
        if (!this.deadlineStr) return;
        
        this.deadline = new Date(this.deadlineStr);
        this.startCountdown();
        this.checkDeadline();
      }

      disconnectedCallback() {
        if (this.interval) {
          clearInterval(this.interval);
        }
      }

      startCountdown() {
        this.updateCountdown();
        this.interval = setInterval(() => {
          this.updateCountdown();
        }, 1000);
      }

      updateCountdown() {
        const now = new Date().getTime();
        const distance = this.deadline.getTime() - now;

        if (distance < 0) {
          this.showClosedState();
          return;
        }

        const days = Math.floor(distance / (1000 * 60 * 60 * 24));
        const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
        const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
        const seconds = Math.floor((distance % (1000 * 60)) / 1000);

        const daysEl = this.countdownEl.querySelector('[data-days]');
        const hoursEl = this.countdownEl.querySelector('[data-hours]');
        const minutesEl = this.countdownEl.querySelector('[data-minutes]');
        const secondsEl = this.countdownEl.querySelector('[data-seconds]');

        if (daysEl) daysEl.textContent = String(days).padStart(2, '0');
        if (hoursEl) hoursEl.textContent = String(hours).padStart(2, '0');
        if (minutesEl) minutesEl.textContent = String(minutes).padStart(2, '0');
        if (secondsEl) secondsEl.textContent = String(seconds).padStart(2, '0');
      }

      checkDeadline() {
        const now = new Date().getTime();
        if (this.deadline.getTime() - now < 0) {
          this.showClosedState();
        }
      }

      showClosedState() {
        if (this.interval) {
          clearInterval(this.interval);
        }
        if (this.formContainer) {
          this.formContainer.style.display = 'none';
        }
        if (this.closedMessage) {
          this.closedMessage.style.display = 'block';
        }
      }
    }

    customElements.define('wc-prediction-widget-{{ ai_gen_id }}', WcPredictionWidget{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "WK voorspelling widget",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Wedstrijd details"
    },
    {
      "type": "text",
      "id": "match_title",
      "label": "Wedstrijd titel",
      "default": "Marokko vs Brazilië — 14 juni 2026"
    },
    {
      "type": "text",
      "id": "team1_name",
      "label": "Team 1 naam",
      "default": "Marokko"
    },
    {
      "type": "text",
      "id": "team2_name",
      "label": "Team 2 naam",
      "default": "Brazilië"
    },
    {
      "type": "text",
      "id": "deadline_datetime",
      "label": "Deadline (ISO format)",
      "default": "2026-06-14T18:00:00Z",
      "info": "Format: YYYY-MM-DDTHH:MM:SSZ (UTC tijd). Bijv: 2026-06-14T18:00:00Z voor 20:00 CEST"
    },
    {
      "type": "text",
      "id": "contest_tag",
      "label": "Contest tag",
      "default": "mar-bra-2026",
      "info": "Unieke tag voor deze wedstrijd"
    },
    {
      "type": "header",
      "content": "Teksten"
    },
    {
      "type": "text",
      "id": "scarcity_text",
      "label": "Scarcity badge tekst",
      "default": "Nog ~20 shirts beschikbaar"
    },
    {
      "type": "text",
      "id": "submit_text",
      "label": "Submit button tekst",
      "default": "Doe mee"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success bericht",
      "default": "Jouw voorspelling is opgeslagen! Je hoort van ons als je gewonnen hebt."
    },
    {
      "type": "text",
      "id": "closed_message",
      "label": "Gesloten bericht",
      "default": "De inzending is gesloten."
    },
    {
      "type": "text",
      "id": "prize_1_text",
      "label": "Prijs 1 tekst",
      "default": "Juiste score → €20 korting"
    },
    {
      "type": "text",
      "id": "prize_2_text",
      "label": "Prijs 2 tekst",
      "default": "Juiste score + doelpuntenmaker → Gratis shirt"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
