{% doc %}
  @prompt
    Create a World Cup prediction widget section for a Shopify page with a dark premium streetwear aesthetic. Same layout, same countdown timer style, same form structure, same prize section layout as a previously built version.
    
    DESIGN:
    - Dark background #000000, white text, gold accent #c9a84c
    - Minimal, editorial typography
    - Clean form inputs with dark styling
    - Gold submit button
    - Countdown timer displayed as blocks showing days, hours, minutes, seconds — streetwear drop timer style
    
    CONTENT (ALL TEXT IN ENGLISH):
    - Header: "Morocco vs Brazil — June 14, 2026"
    - Live countdown timer to June 13 2026 00:10 CEST (June 12 2026 22:10 UTC) — show DD:HH:MM:SS blocks with labels "Days", "Hours", "Minutes", "Seconds"
    - After deadline show "Submissions closed" and hide the form
    - Scarcity badge: "~18 shirts remaining" in gold
    - Form fields:
      - Email (required, label: "Your email address")
      - Two side-by-side number inputs for Morocco and Brazil scores (min 0, integers only), labeled "Morocco" and "Brazil"
      - Optional text field: "Goalscorers (optional)" with placeholder "e.g. Hakimi, En-Nesyri, Vinicius — comma-separated"
      - Submit button: "Enter now"
    - Success message: "Your prediction has been saved! We'll let you know if you've won."
    - Prizes section below the form:
      - "🎯 Correct score → €15 discount"
      - "🏆 Correct score + goalscorer → Free shirt"
    
    FUNCTIONALITY:
    - Deadline: June 13 2026 00:10 CEST (June 12 2026 22:10 UTC) — after this, hide form and show "Submissions are closed."
    - On submit: save customer with email, add tags "wk-voorspelling" and "mar-bra-2026", store prediction in customer note or metafield
    - DUPLICATE CHECK: only show "You've already entered!" if the email has ALREADY submitted a prediction for this contest (has tag mar-bra-2026 AND stored prediction). Do NOT block existing customers who have not yet submitted a prediction.
    - All text in English
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-wc-prediction-{{ ai_gen_id }} {
    display: block;
    background-color: {{ block.settings.background_color }};
    color: {{ block.settings.text_color }};
    padding: 60px 20px;
    width: 100%;
  }

  .ai-wc-prediction-container-{{ ai_gen_id }} {
    max-width: 600px;
    margin: 0 auto;
  }

  .ai-wc-prediction-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 40px;
  }

  .ai-wc-prediction-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: 700;
    margin: 0 0 20px;
    letter-spacing: 0.5px;
    text-transform: uppercase;
  }

  .ai-wc-prediction-scarcity-{{ ai_gen_id }} {
    display: inline-block;
    background-color: {{ block.settings.accent_color }};
    color: {{ block.settings.background_color }};
    padding: 8px 16px;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.5px;
    margin-top: 10px;
  }

  .ai-wc-prediction-countdown-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: 16px;
    margin-bottom: 40px;
  }

  .ai-wc-prediction-countdown-block-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: 70px;
  }

  .ai-wc-prediction-countdown-value-{{ ai_gen_id }} {
    background-color: {{ block.settings.countdown_bg }};
    color: {{ block.settings.countdown_text }};
    font-size: 32px;
    font-weight: 700;
    padding: 16px 12px;
    min-width: 70px;
    text-align: center;
    border: 1px solid {{ block.settings.countdown_border }};
    font-variant-numeric: tabular-nums;
  }

  .ai-wc-prediction-countdown-label-{{ ai_gen_id }} {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-top: 8px;
    opacity: 0.7;
  }

  .ai-wc-prediction-closed-{{ ai_gen_id }} {
    text-align: center;
    font-size: 20px;
    font-weight: 600;
    padding: 40px 20px;
    opacity: 0.7;
  }

  .ai-wc-prediction-form-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .ai-wc-prediction-field-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ai-wc-prediction-label-{{ ai_gen_id }} {
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .ai-wc-prediction-input-{{ ai_gen_id }} {
    background-color: {{ block.settings.input_bg }};
    color: {{ block.settings.text_color }};
    border: 1px solid {{ block.settings.input_border }};
    padding: 14px 16px;
    font-size: 15px;
    width: 100%;
  }

  .ai-wc-prediction-input-{{ ai_gen_id }}::placeholder {
    color: {{ block.settings.text_color }};
    opacity: 0.5;
  }

  .ai-wc-prediction-input-{{ ai_gen_id }}:focus {
    outline: none;
    border-color: {{ block.settings.accent_color }};
  }

  .ai-wc-prediction-score-row-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .ai-wc-prediction-submit-{{ ai_gen_id }} {
    background-color: {{ block.settings.accent_color }};
    color: {{ block.settings.background_color }};
    border: none;
    padding: 16px 32px;
    font-size: 15px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    cursor: pointer;
    transition: opacity 0.3s ease;
    margin-top: 10px;
  }

  .ai-wc-prediction-submit-{{ ai_gen_id }}:hover {
    opacity: 0.85;
  }

  .ai-wc-prediction-submit-{{ ai_gen_id }}:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .ai-wc-prediction-message-{{ ai_gen_id }} {
    padding: 16px;
    text-align: center;
    font-size: 15px;
    margin-top: 20px;
    border: 1px solid;
  }

  .ai-wc-prediction-message-success-{{ ai_gen_id }} {
    background-color: rgba(201, 168, 76, 0.1);
    border-color: {{ block.settings.accent_color }};
    color: {{ block.settings.accent_color }};
  }

  .ai-wc-prediction-message-error-{{ ai_gen_id }} {
    background-color: rgba(255, 0, 0, 0.1);
    border-color: #ff0000;
    color: #ff6666;
  }

  .ai-wc-prediction-prizes-{{ ai_gen_id }} {
    margin-top: 50px;
    padding-top: 40px;
    border-top: 1px solid {{ block.settings.input_border }};
  }

  .ai-wc-prediction-prize-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px 0;
    font-size: 15px;
  }

  .ai-wc-prediction-prize-icon-{{ ai_gen_id }} {
    font-size: 24px;
  }

  .ai-wc-prediction-already-entered-{{ ai_gen_id }} {
    text-align: center;
    padding: 40px 20px;
    font-size: 18px;
    font-weight: 600;
    color: {{ block.settings.accent_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-wc-prediction-{{ ai_gen_id }} {
      padding: 40px 16px;
    }

    .ai-wc-prediction-countdown-{{ ai_gen_id }} {
      gap: 10px;
    }

    .ai-wc-prediction-countdown-block-{{ ai_gen_id }} {
      min-width: 60px;
    }

    .ai-wc-prediction-countdown-value-{{ ai_gen_id }} {
      font-size: 24px;
      padding: 12px 8px;
      min-width: 60px;
    }

    .ai-wc-prediction-countdown-label-{{ ai_gen_id }} {
      font-size: 10px;
    }

    .ai-wc-prediction-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.7 }}px;
    }
  }
{% endstyle %}

<world-cup-prediction-{{ ai_gen_id }}
  class="ai-wc-prediction-{{ ai_gen_id }}"
  data-deadline="{{ block.settings.deadline_utc }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-wc-prediction-container-{{ ai_gen_id }}">
    <div class="ai-wc-prediction-header-{{ ai_gen_id }}">
      <h2 class="ai-wc-prediction-title-{{ ai_gen_id }}">{{ block.settings.match_title }}</h2>
      <div class="ai-wc-prediction-scarcity-{{ ai_gen_id }}">{{ block.settings.scarcity_text }}</div>
    </div>

    <div class="ai-wc-prediction-countdown-{{ ai_gen_id }}" data-countdown>
      <div class="ai-wc-prediction-countdown-block-{{ ai_gen_id }}">
        <div class="ai-wc-prediction-countdown-value-{{ ai_gen_id }}" data-days>00</div>
        <div class="ai-wc-prediction-countdown-label-{{ ai_gen_id }}">Days</div>
      </div>
      <div class="ai-wc-prediction-countdown-block-{{ ai_gen_id }}">
        <div class="ai-wc-prediction-countdown-value-{{ ai_gen_id }}" data-hours>00</div>
        <div class="ai-wc-prediction-countdown-label-{{ ai_gen_id }}">Hours</div>
      </div>
      <div class="ai-wc-prediction-countdown-block-{{ ai_gen_id }}">
        <div class="ai-wc-prediction-countdown-value-{{ ai_gen_id }}" data-minutes>00</div>
        <div class="ai-wc-prediction-countdown-label-{{ ai_gen_id }}">Minutes</div>
      </div>
      <div class="ai-wc-prediction-countdown-block-{{ ai_gen_id }}">
        <div class="ai-wc-prediction-countdown-value-{{ ai_gen_id }}" data-seconds>00</div>
        <div class="ai-wc-prediction-countdown-label-{{ ai_gen_id }}">Seconds</div>
      </div>
    </div>

    <div class="ai-wc-prediction-closed-{{ ai_gen_id }}" data-closed style="display: none;">
      {{ block.settings.closed_message }}
    </div>

    <div class="ai-wc-prediction-already-entered-{{ ai_gen_id }}" data-already-entered style="display: none;">
      You've already entered!
    </div>

    <div data-form-container>
      {%- form 'contact' -%}
        <input type="hidden" name="contact[tags]" value="{{ block.settings.customer_tags }}">
        <input type="hidden" name="contact[contest_id]" value="{{ block.settings.contest_id }}">
        <input type="hidden" name="contact[prediction_data]" data-prediction-field>

        <div class="ai-wc-prediction-form-{{ ai_gen_id }}">
          <div class="ai-wc-prediction-field-{{ ai_gen_id }}">
            <label class="ai-wc-prediction-label-{{ ai_gen_id }}" for="email-{{ ai_gen_id }}">
              {{ block.settings.email_label }}
            </label>
            <input
              type="email"
              id="email-{{ ai_gen_id }}"
              name="contact[email]"
              class="ai-wc-prediction-input-{{ ai_gen_id }}"
              required
              autocomplete="email"
              data-email-input
            >
          </div>

          <div class="ai-wc-prediction-score-row-{{ ai_gen_id }}">
            <div class="ai-wc-prediction-field-{{ ai_gen_id }}">
              <label class="ai-wc-prediction-label-{{ ai_gen_id }}" for="morocco-{{ ai_gen_id }}">
                {{ block.settings.team_1_label }}
              </label>
              <input
                type="number"
                id="morocco-{{ ai_gen_id }}"
                class="ai-wc-prediction-input-{{ ai_gen_id }}"
                min="0"
                step="1"
                value="0"
                required
                data-morocco-score
              >
            </div>

            <div class="ai-wc-prediction-field-{{ ai_gen_id }}">
              <label class="ai-wc-prediction-label-{{ ai_gen_id }}" for="brazil-{{ ai_gen_id }}">
                {{ block.settings.team_2_label }}
              </label>
              <input
                type="number"
                id="brazil-{{ ai_gen_id }}"
                class="ai-wc-prediction-input-{{ ai_gen_id }}"
                min="0"
                step="1"
                value="0"
                required
                data-brazil-score
              >
            </div>
          </div>

          <div class="ai-wc-prediction-field-{{ ai_gen_id }}">
            <label class="ai-wc-prediction-label-{{ ai_gen_id }}" for="goalscorers-{{ ai_gen_id }}">
              {{ block.settings.goalscorers_label }}
            </label>
            <input
              type="text"
              id="goalscorers-{{ ai_gen_id }}"
              class="ai-wc-prediction-input-{{ ai_gen_id }}"
              placeholder="{{ block.settings.goalscorers_placeholder }}"
              data-goalscorers
            >
          </div>

          <button
            type="submit"
            class="ai-wc-prediction-submit-{{ ai_gen_id }}"
            data-submit-button
          >
            {{ block.settings.submit_text }}
          </button>
        </div>

        <div
          class="ai-wc-prediction-message-{{ ai_gen_id }} ai-wc-prediction-message-success-{{ ai_gen_id }}"
          data-success-message
          style="display: none;"
        >
          {{ block.settings.success_message }}
        </div>

        <div
          class="ai-wc-prediction-message-{{ ai_gen_id }} ai-wc-prediction-message-error-{{ ai_gen_id }}"
          data-error-message
          style="display: none;"
        >
        </div>
      {%- endform -%}
    </div>

    <div class="ai-wc-prediction-prizes-{{ ai_gen_id }}">
      <div class="ai-wc-prediction-prize-{{ ai_gen_id }}">
        <span class="ai-wc-prediction-prize-icon-{{ ai_gen_id }}">🎯</span>
        <span>{{ block.settings.prize_1_text }}</span>
      </div>
      <div class="ai-wc-prediction-prize-{{ ai_gen_id }}">
        <span class="ai-wc-prediction-prize-icon-{{ ai_gen_id }}">🏆</span>
        <span>{{ block.settings.prize_2_text }}</span>
      </div>
    </div>
  </div>
</world-cup-prediction-{{ ai_gen_id }}>

<script>
  (function() {
    class WorldCupPrediction{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.deadlineUTC = this.dataset.deadline;
        this.countdownEl = this.querySelector('[data-countdown]');
        this.closedEl = this.querySelector('[data-closed]');
        this.formContainer = this.querySelector('[data-form-container]');
        this.alreadyEnteredEl = this.querySelector('[data-already-entered]');
        this.daysEl = this.querySelector('[data-days]');
        this.hoursEl = this.querySelector('[data-hours]');
        this.minutesEl = this.querySelector('[data-minutes]');
        this.secondsEl = this.querySelector('[data-seconds]');
        this.form = this.querySelector('form');
        this.emailInput = this.querySelector('[data-email-input]');
        this.moroccoInput = this.querySelector('[data-morocco-score]');
        this.brazilInput = this.querySelector('[data-brazil-score]');
        this.goalscorersInput = this.querySelector('[data-goalscorers]');
        this.predictionField = this.querySelector('[data-prediction-field]');
        this.submitButton = this.querySelector('[data-submit-button]');
        this.successMessage = this.querySelector('[data-success-message]');
        this.errorMessage = this.querySelector('[data-error-message]');
        this.countdownInterval = null;
      }

      connectedCallback() {
        this.startCountdown();
        this.setupFormHandling();
        this.checkExistingEntry();
      }

      disconnectedCallback() {
        if (this.countdownInterval) {
          clearInterval(this.countdownInterval);
        }
      }

      startCountdown() {
        const updateCountdown = () => {
          const now = new Date().getTime();
          const deadline = new Date(this.deadlineUTC).getTime();
          const distance = deadline - now;

          if (distance < 0) {
            clearInterval(this.countdownInterval);
            this.showClosed();
            return;
          }

          const days = Math.floor(distance / (1000 * 60 * 60 * 24));
          const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
          const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
          const seconds = Math.floor((distance % (1000 * 60)) / 1000);

          this.daysEl.textContent = String(days).padStart(2, '0');
          this.hoursEl.textContent = String(hours).padStart(2, '0');
          this.minutesEl.textContent = String(minutes).padStart(2, '0');
          this.secondsEl.textContent = String(seconds).padStart(2, '0');
        };

        updateCountdown();
        this.countdownInterval = setInterval(updateCountdown, 1000);
      }

      showClosed() {
        this.countdownEl.style.display = 'none';
        this.formContainer.style.display = 'none';
        this.closedEl.style.display = 'block';
      }

      checkExistingEntry() {
        const email = this.emailInput.value;
        if (!email) return;

        const stored = localStorage.getItem('wc_prediction_mar_bra_2026');
        if (stored) {
          try {
            const data = JSON.parse(stored);
            if (data.email === email) {
              this.showAlreadyEntered();
            }
          } catch (e) {
          }
        }
      }

      showAlreadyEntered() {
        this.formContainer.style.display = 'none';
        this.alreadyEnteredEl.style.display = 'block';
      }

      setupFormHandling() {
        this.emailInput.addEventListener('blur', () => {
          this.checkExistingEntry();
        });

        this.form.addEventListener('submit', (e) => {
          e.preventDefault();

          const email = this.emailInput.value;
          const moroccoScore = parseInt(this.moroccoInput.value) || 0;
          const brazilScore = parseInt(this.brazilInput.value) || 0;
          const goalscorers = this.goalscorersInput.value.trim();

          const stored = localStorage.getItem('wc_prediction_mar_bra_2026');
          if (stored) {
            try {
              const data = JSON.parse(stored);
              if (data.email === email) {
                this.showAlreadyEntered();
                return;
              }
            } catch (e) {
            }
          }

          const predictionData = {
            email: email,
            morocco: moroccoScore,
            brazil: brazilScore,
            goalscorers: goalscorers,
            timestamp: new Date().toISOString()
          };

          this.predictionField.value = JSON.stringify(predictionData);

          this.submitButton.disabled = true;
          this.submitButton.textContent = 'Submitting...';

          fetch(this.form.action, {
            method: 'POST',
            body: new FormData(this.form),
            headers: {
              'Accept': 'application/json'
            }
          })
          .then(response => {
            if (response.ok) {
              localStorage.setItem('wc_prediction_mar_bra_2026', JSON.stringify(predictionData));
              this.successMessage.style.display = 'block';
              this.form.style.display = 'none';
            } else {
              throw new Error('Submission failed');
            }
          })
          .catch(error => {
            this.errorMessage.textContent = 'Something went wrong. Please try again.';
            this.errorMessage.style.display = 'block';
            this.submitButton.disabled = false;
            this.submitButton.textContent = this.submitButton.dataset.originalText || 'Enter now';
          });
        });

        this.submitButton.dataset.originalText = this.submitButton.textContent;
      }
    }

    customElements.define('world-cup-prediction-{{ ai_gen_id }}', WorldCupPrediction{{ ai_gen_id }});
  })();
</script>

