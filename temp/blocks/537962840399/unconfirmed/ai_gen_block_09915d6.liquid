{% doc %}
  @prompt
    Create a World Cup prediction widget section for a Shopify page with a dark premium streetwear aesthetic.
    
    DESIGN:
    - Dark background #000000, white text, gold accent #c9a84c
    - Minimal, editorial typography
    - Clean form inputs with dark styling
    - Gold submit button
    
    CONTENT (ALL TEXT IN ENGLISH):
    - Header: "Morocco vs Brazil — June 14, 2026"
    - Live countdown to June 14 2026 20:00 CEST (18:00 UTC)
    - Scarcity badge: "~20 shirts remaining" in gold
    - Form fields: email (required, label: "Your email address"), two side-by-side number inputs for Morocco and Brazil scores (min 0, integers only), optional text field for goalscorers (comma-separated, placeholder: "e.g. Hakimi, En-Nesyri, Vinicius — comma-separated")
    - Submit button: "Enter now"
    - Success message: "Your prediction has been saved! We'll let you know if you've won."
    - Prizes: "🎯 Correct score → €20 discount" and "🏆 Correct score + goalscorer → Free shirt"
    
    FUNCTIONALITY:
    - After deadline (June 14 2026 20:00 CEST / 18:00 UTC): hide form, show "Submissions are closed."
    - On submit: save customer with email, add tags "wk-voorspelling" and "mar-bra-2026", store prediction in customer note or metafield
    - DUPLICATE CHECK: only show "You've already entered!" if the email has ALREADY submitted a prediction for this contest (has tag mar-bra-2026 AND stored prediction). Do NOT block existing customers who have not yet submitted a prediction.
    - All text in English
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-wc-prediction-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: 60px 40px;
    color: {{ block.settings.text_color }};
  }

  .ai-wc-prediction__container-{{ ai_gen_id }} {
    max-width: 600px;
    margin: 0 auto;
  }

  .ai-wc-prediction__header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 40px;
  }

  .ai-wc-prediction__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0 0 20px;
    color: {{ block.settings.text_color }};
  }

  .ai-wc-prediction__countdown-{{ ai_gen_id }} {
    font-size: 18px;
    margin-bottom: 16px;
    font-weight: 500;
    letter-spacing: 0.02em;
  }

  .ai-wc-prediction__badge-{{ ai_gen_id }} {
    display: inline-block;
    background-color: {{ block.settings.accent_color }};
    color: {{ block.settings.background_color }};
    padding: 8px 16px;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .ai-wc-prediction__form-{{ ai_gen_id }} {
    margin-bottom: 40px;
  }

  .ai-wc-prediction__field-{{ ai_gen_id }} {
    margin-bottom: 24px;
  }

  .ai-wc-prediction__label-{{ ai_gen_id }} {
    display: block;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-bottom: 8px;
    color: {{ block.settings.text_color }};
  }

  .ai-wc-prediction__input-{{ ai_gen_id }} {
    width: 100%;
    padding: 14px 16px;
    background-color: {{ block.settings.input_bg_color }};
    border: 1px solid {{ block.settings.input_border_color }};
    color: {{ block.settings.text_color }};
    font-size: 15px;
    transition: border-color 0.2s ease;
  }

  .ai-wc-prediction__input-{{ ai_gen_id }}:focus {
    outline: none;
    border-color: {{ block.settings.accent_color }};
  }

  .ai-wc-prediction__input-{{ ai_gen_id }}::placeholder {
    color: {{ block.settings.placeholder_color }};
  }

  .ai-wc-prediction__score-row-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .ai-wc-prediction__score-field-{{ ai_gen_id }} {
    text-align: center;
  }

  .ai-wc-prediction__team-label-{{ ai_gen_id }} {
    display: block;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-bottom: 8px;
    color: {{ block.settings.text_color }};
  }

  .ai-wc-prediction__score-input-{{ ai_gen_id }} {
    width: 100%;
    padding: 14px 16px;
    background-color: {{ block.settings.input_bg_color }};
    border: 1px solid {{ block.settings.input_border_color }};
    color: {{ block.settings.text_color }};
    font-size: 24px;
    font-weight: 700;
    text-align: center;
    transition: border-color 0.2s ease;
  }

  .ai-wc-prediction__score-input-{{ ai_gen_id }}:focus {
    outline: none;
    border-color: {{ block.settings.accent_color }};
  }

  .ai-wc-prediction__button-{{ ai_gen_id }} {
    width: 100%;
    padding: 16px 32px;
    background-color: {{ block.settings.accent_color }};
    color: {{ block.settings.background_color }};
    border: none;
    font-size: 15px;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    cursor: pointer;
    transition: opacity 0.2s ease;
  }

  .ai-wc-prediction__button-{{ ai_gen_id }}:hover {
    opacity: 0.9;
  }

  .ai-wc-prediction__button-{{ ai_gen_id }}:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .ai-wc-prediction__prizes-{{ ai_gen_id }} {
    border-top: 1px solid {{ block.settings.input_border_color }};
    padding-top: 32px;
  }

  .ai-wc-prediction__prize-{{ ai_gen_id }} {
    font-size: 15px;
    margin-bottom: 12px;
    line-height: 1.6;
  }

  .ai-wc-prediction__message-{{ ai_gen_id }} {
    padding: 16px 20px;
    margin-bottom: 24px;
    text-align: center;
    font-size: 15px;
    font-weight: 500;
  }

  .ai-wc-prediction__message--success-{{ ai_gen_id }} {
    background-color: {{ block.settings.success_bg_color }};
    color: {{ block.settings.success_text_color }};
    border: 1px solid {{ block.settings.success_text_color }};
  }

  .ai-wc-prediction__message--error-{{ ai_gen_id }} {
    background-color: {{ block.settings.error_bg_color }};
    color: {{ block.settings.error_text_color }};
    border: 1px solid {{ block.settings.error_text_color }};
  }

  .ai-wc-prediction__message--info-{{ ai_gen_id }} {
    background-color: {{ block.settings.input_bg_color }};
    color: {{ block.settings.text_color }};
    border: 1px solid {{ block.settings.input_border_color }};
  }

  .ai-wc-prediction__hidden-{{ ai_gen_id }} {
    display: none;
  }

  @media screen and (max-width: 749px) {
    .ai-wc-prediction-{{ ai_gen_id }} {
      padding: 40px 20px;
    }

    .ai-wc-prediction__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.7 }}px;
    }

    .ai-wc-prediction__countdown-{{ ai_gen_id }} {
      font-size: 16px;
    }
  }
{% endstyle %}

<wc-prediction-{{ ai_gen_id }}
  class="ai-wc-prediction-{{ ai_gen_id }}"
  data-deadline="{{ block.settings.deadline_date }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-wc-prediction__container-{{ ai_gen_id }}">
    <div class="ai-wc-prediction__header-{{ ai_gen_id }}">
      <h2 class="ai-wc-prediction__title-{{ ai_gen_id }}">{{ block.settings.match_title }}</h2>
      <div class="ai-wc-prediction__countdown-{{ ai_gen_id }}" data-countdown></div>
      <div class="ai-wc-prediction__badge-{{ ai_gen_id }}">{{ block.settings.scarcity_text }}</div>
    </div>

    <div class="ai-wc-prediction__message-{{ ai_gen_id }} ai-wc-prediction__message--success-{{ ai_gen_id }} ai-wc-prediction__hidden-{{ ai_gen_id }}" data-success-message>
      {{ block.settings.success_message }}
    </div>

    <div class="ai-wc-prediction__message-{{ ai_gen_id }} ai-wc-prediction__message--error-{{ ai_gen_id }} ai-wc-prediction__hidden-{{ ai_gen_id }}" data-error-message></div>

    <div class="ai-wc-prediction__message-{{ ai_gen_id }} ai-wc-prediction__message--info-{{ ai_gen_id }} ai-wc-prediction__hidden-{{ ai_gen_id }}" data-closed-message>
      Submissions are closed.
    </div>

    <div data-form-container>
      {%- form 'contact' -%}
        <input type="hidden" name="contact[tags]" value="wk-voorspelling,mar-bra-2026">
        
        <div class="ai-wc-prediction__form-{{ ai_gen_id }}">
          <div class="ai-wc-prediction__field-{{ ai_gen_id }}">
            <label class="ai-wc-prediction__label-{{ ai_gen_id }}" for="ai-wc-email-{{ ai_gen_id }}">
              {{ block.settings.email_label }}
            </label>
            <input
              type="email"
              id="ai-wc-email-{{ ai_gen_id }}"
              name="contact[email]"
              class="ai-wc-prediction__input-{{ ai_gen_id }}"
              required
              autocomplete="email"
              data-email-input
            >
          </div>

          <div class="ai-wc-prediction__field-{{ ai_gen_id }}">
            <label class="ai-wc-prediction__label-{{ ai_gen_id }}">
              {{ block.settings.score_label }}
            </label>
            <div class="ai-wc-prediction__score-row-{{ ai_gen_id }}">
              <div class="ai-wc-prediction__score-field-{{ ai_gen_id }}">
                <span class="ai-wc-prediction__team-label-{{ ai_gen_id }}">{{ block.settings.team_1_name }}</span>
                <input
                  type="number"
                  name="contact[morocco_score]"
                  class="ai-wc-prediction__score-input-{{ ai_gen_id }}"
                  min="0"
                  step="1"
                  required
                  data-score-input
                >
              </div>
              <div class="ai-wc-prediction__score-field-{{ ai_gen_id }}">
                <span class="ai-wc-prediction__team-label-{{ ai_gen_id }}">{{ block.settings.team_2_name }}</span>
                <input
                  type="number"
                  name="contact[brazil_score]"
                  class="ai-wc-prediction__score-input-{{ ai_gen_id }}"
                  min="0"
                  step="1"
                  required
                  data-score-input
                >
              </div>
            </div>
          </div>

          <div class="ai-wc-prediction__field-{{ ai_gen_id }}">
            <label class="ai-wc-prediction__label-{{ ai_gen_id }}" for="ai-wc-goalscorers-{{ ai_gen_id }}">
              {{ block.settings.goalscorers_label }}
            </label>
            <input
              type="text"
              id="ai-wc-goalscorers-{{ ai_gen_id }}"
              name="contact[goalscorers]"
              class="ai-wc-prediction__input-{{ ai_gen_id }}"
              placeholder="{{ block.settings.goalscorers_placeholder }}"
            >
          </div>

          <input type="hidden" name="contact[prediction_data]" data-prediction-data>

          <button type="submit" class="ai-wc-prediction__button-{{ ai_gen_id }}" data-submit-button>
            {{ block.settings.submit_text }}
          </button>
        </div>
      {%- endform -%}
    </div>

    <div class="ai-wc-prediction__prizes-{{ ai_gen_id }}">
      <div class="ai-wc-prediction__prize-{{ ai_gen_id }}">{{ block.settings.prize_1_text }}</div>
      <div class="ai-wc-prediction__prize-{{ ai_gen_id }}">{{ block.settings.prize_2_text }}</div>
    </div>
  </div>
</wc-prediction-{{ ai_gen_id }}>

<script>
  (function() {
    class WCPrediction{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.deadlineDate = this.dataset.deadline;
        this.countdownEl = this.querySelector('[data-countdown]');
        this.formContainer = this.querySelector('[data-form-container]');
        this.closedMessage = this.querySelector('[data-closed-message]');
        this.successMessage = this.querySelector('[data-success-message]');
        this.errorMessage = this.querySelector('[data-error-message]');
        this.form = this.querySelector('form');
        this.emailInput = this.querySelector('[data-email-input]');
        this.submitButton = this.querySelector('[data-submit-button]');
        this.predictionDataInput = this.querySelector('[data-prediction-data]');
        this.scoreInputs = this.querySelectorAll('[data-score-input]');
      }

      connectedCallback() {
        this.startCountdown();
        this.setupFormHandling();
      }

      startCountdown() {
        const updateCountdown = () => {
          const deadline = new Date(this.deadlineDate).getTime();
          const now = new Date().getTime();
          const distance = deadline - now;

          if (distance < 0) {
            this.countdownEl.textContent = 'Submissions closed';
            this.hideForm();
            return;
          }

          const days = Math.floor(distance / (1000 * 60 * 60 * 24));
          const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
          const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
          const seconds = Math.floor((distance % (1000 * 60)) / 1000);

          let countdownText = '';
          if (days > 0) {
            countdownText = days + 'd ' + hours + 'h ' + minutes + 'm';
          } else if (hours > 0) {
            countdownText = hours + 'h ' + minutes + 'm ' + seconds + 's';
          } else {
            countdownText = minutes + 'm ' + seconds + 's';
          }

          this.countdownEl.textContent = countdownText + ' remaining';
        };

        updateCountdown();
        this.countdownInterval = setInterval(updateCountdown, 1000);
      }

      hideForm() {
        this.formContainer.classList.add('ai-wc-prediction__hidden-{{ ai_gen_id }}');
        this.closedMessage.classList.remove('ai-wc-prediction__hidden-{{ ai_gen_id }}');
      }

      setupFormHandling() {
        this.form.addEventListener('submit', async (e) => {
          e.preventDefault();

          const deadline = new Date(this.deadlineDate).getTime();
          const now = new Date().getTime();
          
          if (now >= deadline) {
            this.showError('Submissions are closed.');
            return;
          }

          const formData = new FormData(this.form);
          const email = formData.get('contact[email]');
          const moroccoScore = formData.get('contact[morocco_score]');
          const brazilScore = formData.get('contact[brazil_score]');
          const goalscorers = formData.get('contact[goalscorers]') || '';

          const predictionData = JSON.stringify({
            match: '{{ block.settings.match_title }}',
            morocco: moroccoScore,
            brazil: brazilScore,
            goalscorers: goalscorers,
            timestamp: new Date().toISOString()
          });

          this.predictionDataInput.value = predictionData;

          this.submitButton.disabled = true;
          this.submitButton.textContent = 'Submitting...';

          try {
            const response = await fetch(this.form.action, {
              method: 'POST',
              body: new FormData(this.form),
              headers: {
                'Accept': 'application/json'
              }
            });

            if (response.ok) {
              this.showSuccess();
              this.form.reset();
            } else {
              const data = await response.json();
              if (data.errors && data.errors.email && data.errors.email.includes('already')) {
                this.showError("You've already entered!");
              } else {
                this.showError('Something went wrong. Please try again.');
              }
            }
          } catch (error) {
            this.showError('Something went wrong. Please try again.');
          } finally {
            this.submitButton.disabled = false;
            this.submitButton.textContent = '{{ block.settings.submit_text }}';
          }
        });

        this.scoreInputs.forEach(input => {
          input.addEventListener('input', (e) => {
            if (e.target.value < 0) {
              e.target.value = 0;
            }
            e.target.value = Math.floor(e.target.value);
          });
        });
      }

      showSuccess() {
        this.successMessage.classList.remove('ai-wc-prediction__hidden-{{ ai_gen_id }}');
        this.errorMessage.classList.add('ai-wc-prediction__hidden-{{ ai_gen_id }}');
        this.formContainer.classList.add('ai-wc-prediction__hidden-{{ ai_gen_id }}');
      }

      showError(message) {
        this.errorMessage.textContent = message;
        this.errorMessage.classList.remove('ai-wc-prediction__hidden-{{ ai_gen_id }}');
        this.successMessage.classList.add('ai-wc-prediction__hidden-{{ ai_gen_id }}');
      }

      disconnectedCallback() {
        if (this.countdownInterval) {
          clearInterval(this.countdownInterval);
        }
      }
    }

    customElements.define('wc-prediction-{{ ai_gen_id }}', WCPrediction{{ ai_gen_id }});
  })();
</script>

