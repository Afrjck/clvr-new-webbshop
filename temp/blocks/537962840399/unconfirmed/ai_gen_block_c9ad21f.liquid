{% doc %}
  @prompt
    Create a World Cup prediction widget section for a Shopify page with a dark premium streetwear aesthetic.
    
    DESIGN:
    - Dark background #000000, white text, gold accent #c9a84c
    - Minimal, editorial typography
    - Clean form inputs with dark styling
    - Gold submit button
    
    CONTENT (ALL TEXT IN ENGLISH):
    - Header: "Morocco vs Brazil — June 14, 2026"
    - Live countdown to June 14 2026 20:00 CEST (18:00 UTC)
    - Scarcity badge: "~20 shirts remaining" in gold
    - Form fields: email (required, label: "Your email address"), two side-by-side number inputs for Morocco and Brazil scores (min 0, integers only), optional text field for goalscorers (comma-separated, placeholder: "e.g. Hakimi, En-Nesyri, Vinicius — comma-separated")
    - Submit button: "Enter now"
    - Success message: "Your prediction has been saved! We'll let you know if you've won."
    - Prizes: "🎯 Correct score → €20 discount" and "🏆 Correct score + goalscorer → Free shirt"
    
    FUNCTIONALITY:
    - After deadline (June 14 2026 20:00 CEST / 18:00 UTC): hide form, show "Submissions are closed."
    - On submit: save customer with email, add tags "wk-voorspelling" and "mar-bra-2026", store prediction in customer note or metafield
    - DUPLICATE CHECK: only show "You've already entered!" if the email has ALREADY submitted a prediction for this contest (has tag mar-bra-2026 AND stored prediction). Do NOT block existing customers who have not yet submitted a prediction.
    - All text in English
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-wc-prediction-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    background-color: {{ block.settings.background_color }};
    color: {{ block.settings.text_color }};
    padding: 60px 40px;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-wc-prediction__container-{{ ai_gen_id }} {
    max-width: 600px;
    margin: 0 auto;
  }

  .ai-wc-prediction__header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 40px;
  }

  .ai-wc-prediction__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0 0 24px;
    color: {{ block.settings.text_color }};
  }

  .ai-wc-prediction__countdown-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: 20px;
    margin-bottom: 20px;
  }

  .ai-wc-prediction__countdown-item-{{ ai_gen_id }} {
    text-align: center;
  }

  .ai-wc-prediction__countdown-value-{{ ai_gen_id }} {
    font-size: 32px;
    font-weight: 700;
    color: {{ block.settings.accent_color }};
    display: block;
    line-height: 1;
  }

  .ai-wc-prediction__countdown-label-{{ ai_gen_id }} {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-top: 8px;
    opacity: 0.7;
  }

  .ai-wc-prediction__scarcity-{{ ai_gen_id }} {
    display: inline-block;
    background-color: {{ block.settings.accent_color }};
    color: {{ block.settings.background_color }};
    padding: 8px 16px;
    border-radius: 4px;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  .ai-wc-prediction__form-{{ ai_gen_id }} {
    margin-top: 40px;
  }

  .ai-wc-prediction__field-{{ ai_gen_id }} {
    margin-bottom: 24px;
  }

  .ai-wc-prediction__label-{{ ai_gen_id }} {
    display: block;
    font-size: 13px;
    font-weight: 600;
    margin-bottom: 8px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .ai-wc-prediction__input-{{ ai_gen_id }} {
    width: 100%;
    padding: 14px 16px;
    background-color: {{ block.settings.input_bg_color }};
    border: 1px solid {{ block.settings.input_border_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    color: {{ block.settings.text_color }};
    font-size: 15px;
    transition: border-color 0.2s ease;
  }

  .ai-wc-prediction__input-{{ ai_gen_id }}:focus {
    outline: none;
    border-color: {{ block.settings.accent_color }};
  }

  .ai-wc-prediction__input-{{ ai_gen_id }}::placeholder {
    color: {{ block.settings.text_color }};
    opacity: 0.5;
  }

  .ai-wc-prediction__score-row-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .ai-wc-prediction__score-field-{{ ai_gen_id }} {
    text-align: center;
  }

  .ai-wc-prediction__team-label-{{ ai_gen_id }} {
    display: block;
    font-size: 14px;
    font-weight: 600;
    margin-bottom: 8px;
    letter-spacing: 0.02em;
  }

  .ai-wc-prediction__score-input-{{ ai_gen_id }} {
    width: 100%;
    padding: 16px;
    background-color: {{ block.settings.input_bg_color }};
    border: 1px solid {{ block.settings.input_border_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    color: {{ block.settings.text_color }};
    font-size: 24px;
    font-weight: 700;
    text-align: center;
    transition: border-color 0.2s ease;
  }

  .ai-wc-prediction__score-input-{{ ai_gen_id }}:focus {
    outline: none;
    border-color: {{ block.settings.accent_color }};
  }

  .ai-wc-prediction__button-{{ ai_gen_id }} {
    width: 100%;
    padding: 18px 32px;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: 16px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .ai-wc-prediction__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
    transform: translateY(-2px);
  }

  .ai-wc-prediction__button-{{ ai_gen_id }}:disabled {
    opacity: 0.5;
    cursor: not-allowed;
    transform: none;
  }

  .ai-wc-prediction__prizes-{{ ai_gen_id }} {
    margin-top: 32px;
    padding-top: 32px;
    border-top: 1px solid {{ block.settings.input_border_color }};
  }

  .ai-wc-prediction__prize-{{ ai_gen_id }} {
    font-size: 14px;
    margin-bottom: 12px;
    opacity: 0.9;
  }

  .ai-wc-prediction__message-{{ ai_gen_id }} {
    padding: 16px 20px;
    border-radius: {{ block.settings.input_border_radius }}px;
    font-size: 15px;
    text-align: center;
    margin-top: 24px;
  }

  .ai-wc-prediction__success-{{ ai_gen_id }} {
    background-color: {{ block.settings.accent_color }};
    color: {{ block.settings.background_color }};
  }

  .ai-wc-prediction__error-{{ ai_gen_id }} {
    background-color: #ff4444;
    color: #ffffff;
  }

  .ai-wc-prediction__closed-{{ ai_gen_id }} {
    text-align: center;
    padding: 40px 20px;
    font-size: 18px;
    opacity: 0.7;
  }

  .ai-wc-prediction__hidden-{{ ai_gen_id }} {
    display: none;
  }

  @media screen and (max-width: 749px) {
    .ai-wc-prediction-{{ ai_gen_id }} {
      padding: 40px 24px;
    }

    .ai-wc-prediction__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.7 }}px;
    }

    .ai-wc-prediction__countdown-value-{{ ai_gen_id }} {
      font-size: 24px;
    }

    .ai-wc-prediction__countdown-{{ ai_gen_id }} {
      gap: 12px;
    }
  }
{% endstyle %}

<world-cup-prediction-{{ ai_gen_id }}
  class="ai-wc-prediction-{{ ai_gen_id }}"
  data-deadline="{{ block.settings.deadline_datetime }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-wc-prediction__container-{{ ai_gen_id }}">
    <div class="ai-wc-prediction__header-{{ ai_gen_id }}">
      <h2 class="ai-wc-prediction__title-{{ ai_gen_id }}">{{ block.settings.match_title }}</h2>
      
      <div class="ai-wc-prediction__countdown-{{ ai_gen_id }}" data-countdown>
        <div class="ai-wc-prediction__countdown-item-{{ ai_gen_id }}">
          <span class="ai-wc-prediction__countdown-value-{{ ai_gen_id }}" data-days>00</span>
          <span class="ai-wc-prediction__countdown-label-{{ ai_gen_id }}">Days</span>
        </div>
        <div class="ai-wc-prediction__countdown-item-{{ ai_gen_id }}">
          <span class="ai-wc-prediction__countdown-value-{{ ai_gen_id }}" data-hours>00</span>
          <span class="ai-wc-prediction__countdown-label-{{ ai_gen_id }}">Hours</span>
        </div>
        <div class="ai-wc-prediction__countdown-item-{{ ai_gen_id }}">
          <span class="ai-wc-prediction__countdown-value-{{ ai_gen_id }}" data-minutes>00</span>
          <span class="ai-wc-prediction__countdown-label-{{ ai_gen_id }}">Minutes</span>
        </div>
        <div class="ai-wc-prediction__countdown-item-{{ ai_gen_id }}">
          <span class="ai-wc-prediction__countdown-value-{{ ai_gen_id }}" data-seconds>00</span>
          <span class="ai-wc-prediction__countdown-label-{{ ai_gen_id }}">Seconds</span>
        </div>
      </div>

      <div style="margin-top: 20px;">
        <span class="ai-wc-prediction__scarcity-{{ ai_gen_id }}">{{ block.settings.scarcity_text }}</span>
      </div>
    </div>

    <div data-form-container>
      {%- form 'contact' -%}
        <input type="hidden" name="contact[tags]" value="wk-voorspelling,mar-bra-2026">
        
        <div class="ai-wc-prediction__form-{{ ai_gen_id }}">
          <div class="ai-wc-prediction__field-{{ ai_gen_id }}">
            <label class="ai-wc-prediction__label-{{ ai_gen_id }}" for="email-{{ ai_gen_id }}">
              {{ block.settings.email_label }}
            </label>
            <input
              type="email"
              id="email-{{ ai_gen_id }}"
              name="contact[email]"
              class="ai-wc-prediction__input-{{ ai_gen_id }}"
              required
              autocomplete="email"
              data-email-input
            >
          </div>

          <div class="ai-wc-prediction__field-{{ ai_gen_id }}">
            <label class="ai-wc-prediction__label-{{ ai_gen_id }}">
              Your prediction
            </label>
            <div class="ai-wc-prediction__score-row-{{ ai_gen_id }}">
              <div class="ai-wc-prediction__score-field-{{ ai_gen_id }}">
                <span class="ai-wc-prediction__team-label-{{ ai_gen_id }}">{{ block.settings.team_1_name }}</span>
                <input
                  type="number"
                  name="contact[morocco_score]"
                  class="ai-wc-prediction__score-input-{{ ai_gen_id }}"
                  min="0"
                  step="1"
                  required
                  data-score-input
                >
              </div>
              <div class="ai-wc-prediction__score-field-{{ ai_gen_id }}">
                <span class="ai-wc-prediction__team-label-{{ ai_gen_id }}">{{ block.settings.team_2_name }}</span>
                <input
                  type="number"
                  name="contact[brazil_score]"
                  class="ai-wc-prediction__score-input-{{ ai_gen_id }}"
                  min="0"
                  step="1"
                  required
                  data-score-input
                >
              </div>
            </div>
          </div>

          <div class="ai-wc-prediction__field-{{ ai_gen_id }}">
            <label class="ai-wc-prediction__label-{{ ai_gen_id }}" for="goalscorers-{{ ai_gen_id }}">
              {{ block.settings.goalscorers_label }}
            </label>
            <input
              type="text"
              id="goalscorers-{{ ai_gen_id }}"
              name="contact[goalscorers]"
              class="ai-wc-prediction__input-{{ ai_gen_id }}"
              placeholder="{{ block.settings.goalscorers_placeholder }}"
            >
          </div>

          <button
            type="submit"
            class="ai-wc-prediction__button-{{ ai_gen_id }}"
            data-submit-button
          >
            {{ block.settings.button_text }}
          </button>

          <div class="ai-wc-prediction__prizes-{{ ai_gen_id }}">
            <div class="ai-wc-prediction__prize-{{ ai_gen_id }}">{{ block.settings.prize_1 }}</div>
            <div class="ai-wc-prediction__prize-{{ ai_gen_id }}">{{ block.settings.prize_2 }}</div>
          </div>
        </div>

        {%- if form.posted_successfully? -%}
          <div class="ai-wc-prediction__message-{{ ai_gen_id }} ai-wc-prediction__success-{{ ai_gen_id }}">
            {{ block.settings.success_message }}
          </div>
        {%- endif -%}

        {%- if form.errors -%}
          <div class="ai-wc-prediction__message-{{ ai_gen_id }} ai-wc-prediction__error-{{ ai_gen_id }}">
            {% if form.errors.messages.email %}
              {{ form.errors.messages.email }}
            {% else %}
              There was an error submitting your prediction. Please try again.
            {% endif %}
          </div>
        {%- endif -%}
      {%- endform -%}
    </div>

    <div class="ai-wc-prediction__closed-{{ ai_gen_id }} ai-wc-prediction__hidden-{{ ai_gen_id }}" data-closed-message>
      {{ block.settings.closed_message }}
    </div>
  </div>
</world-cup-prediction-{{ ai_gen_id }}>

<script>
  (function() {
    class WorldCupPrediction{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.deadline = new Date(this.dataset.deadline);
        this.countdownElements = {
          days: this.querySelector('[data-days]'),
          hours: this.querySelector('[data-hours]'),
          minutes: this.querySelector('[data-minutes]'),
          seconds: this.querySelector('[data-seconds]')
        };
        this.formContainer = this.querySelector('[data-form-container]');
        this.closedMessage = this.querySelector('[data-closed-message]');
        this.countdownContainer = this.querySelector('[data-countdown]');
      }

      connectedCallback() {
        this.checkDeadline();
        this.startCountdown();
      }

      checkDeadline() {
        const now = new Date();
        if (now >= this.deadline) {
          this.showClosedState();
        }
      }

      showClosedState() {
        if (this.formContainer) {
          this.formContainer.classList.add('ai-wc-prediction__hidden-{{ ai_gen_id }}');
        }
        if (this.closedMessage) {
          this.closedMessage.classList.remove('ai-wc-prediction__hidden-{{ ai_gen_id }}');
        }
        if (this.countdownContainer) {
          this.countdownContainer.style.display = 'none';
        }
      }

      startCountdown() {
        this.updateCountdown();
        this.countdownInterval = setInterval(() => {
          this.updateCountdown();
        }, 1000);
      }

      updateCountdown() {
        const now = new Date();
        const distance = this.deadline - now;

        if (distance < 0) {
          clearInterval(this.countdownInterval);
          this.showClosedState();
          return;
        }

        const days = Math.floor(distance / (1000 * 60 * 60 * 24));
        const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
        const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
        const seconds = Math.floor((distance % (1000 * 60)) / 1000);

        if (this.countdownElements.days) {
          this.countdownElements.days.textContent = String(days).padStart(2, '0');
        }
        if (this.countdownElements.hours) {
          this.countdownElements.hours.textContent = String(hours).padStart(2, '0');
        }
        if (this.countdownElements.minutes) {
          this.countdownElements.minutes.textContent = String(minutes).padStart(2, '0');
        }
        if (this.countdownElements.seconds) {
          this.countdownElements.seconds.textContent = String(seconds).padStart(2, '0');
        }
      }

      disconnectedCallback() {
        if (this.countdownInterval) {
          clearInterval(this.countdownInterval);
        }
      }
    }

    customElements.define('world-cup-prediction-{{ ai_gen_id }}', WorldCupPrediction{{ ai_gen_id }});
  })();
</script>

