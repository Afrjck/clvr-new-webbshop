<script>
(function() {
  class WCPredictionWidget{{ ai_gen_id }} extends HTMLElement {
    constructor() {
      super();
      this.deadline = new Date(this.dataset.deadline);
      this.contestTag = this.dataset.contestTag;
      this.form = this.querySelector('[data-prediction-form]');
      this.emailInput = this.querySelector('[data-email-input]');
      this.team1Input = this.querySelector('[data-team1-score]');
      this.team2Input = this.querySelector('[data-team2-score]');
      this.goalscorersInput = this.querySelector('[data-goalscorers-input]');
      this.successMessage = this.querySelector('[data-success-message]');
      this.errorMessage = this.querySelector('[data-error-message]');
      this.closedMessage = this.querySelector('.ai-wc-closed-{{ ai_gen_id }}');
      this.countdownInterval = null;
    }

    connectedCallback() {
      this.startCountdown();
      this.form.addEventListener('submit', this.handleSubmit.bind(this));
    }

    disconnectedCallback() {
      if (this.countdownInterval) {
        clearInterval(this.countdownInterval);
      }
    }

    startCountdown() {
      const updateCountdown = () => {
        const now = new Date().getTime();
        const distance = this.deadline.getTime() - now;

        if (distance < 0) {
          this.handleDeadlinePassed();
          return;
        }

        const days = Math.floor(distance / (1000 * 60 * 60 * 24));
        const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
        const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
        const seconds = Math.floor((distance % (1000 * 60)) / 1000);

        this.querySelector('[data-countdown-days]').textContent = days;
        this.querySelector('[data-countdown-hours]').textContent = hours;
        this.querySelector('[data-countdown-minutes]').textContent = minutes;
        this.querySelector('[data-countdown-seconds]').textContent = seconds;
      };

      updateCountdown();
      this.countdownInterval = setInterval(updateCountdown, 1000);
    }

    handleDeadlinePassed() {
      if (this.countdownInterval) {
        clearInterval(this.countdownInterval);
      }
      this.form.style.display = 'none';
      this.closedMessage.classList.add('active');
    }

    async handleSubmit(e) {
      e.preventDefault();

      const email = this.emailInput.value.trim();
      const team1Score = parseInt(this.team1Input.value);
      const team2Score = parseInt(this.team2Input.value);
      const goalscorers = this.goalscorersInput.value.trim();

      this.successMessage.classList.remove('active');
      this.errorMessage.classList.remove('active');

      const submitButton = this.form.querySelector('button[type="submit"]');
      submitButton.disabled = true;
      submitButton.textContent = 'Submitting...';

      try {
        const prediction = team1Score + '-' + team2Score + (goalscorers ? ' | ' + goalscorers : '');

        const response = await fetch('/contact', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
          },
          body: new URLSearchParams({
            'form_type': 'customer',
            'utf8': '✓',
            'contact[email]': email,
            'contact[tags]': 'wk-voorspelling,' + this.contestTag,
            'contact[note]': 'Prediction: ' + prediction
          })
        });

        if (response.ok) {
          this.successMessage.classList.add('active');
          this.form.reset();
        } else {
          const text = await response.text();
          if (text.includes('already') || text.includes('exists')) {
            this.errorMessage.textContent = "You've already entered!";
          } else {
            this.errorMessage.textContent = 'Something went wrong. Please try again.';
          }
          this.errorMessage.classList.add('active');
        }
      } catch (error) {
        this.errorMessage.textContent = 'Network error. Please check your connection and try again.';
        this.errorMessage.classList.add('active');
      } finally {
        submitButton.disabled = false;
        submitButton.textContent = '{{ block.settings.submit_text }}';
      }
    }
  }

  customElements.define('wc-prediction-widget-{{ ai_gen_id }}', WCPredictionWidget{{ ai_gen_id }});
})();
</script>

