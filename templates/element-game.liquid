n  const RECIPES = {\n    'stof+verf':        'print',\n    'print+stof':       'shirt',\n    'nacht+straat':     'drop',\n    'drop+shirt':       'hype',\n    'hype+shirt':       'collectie',\n    'collectie+straat': 'clvr_shirt',\n    'straat+verf':      'cultuur',\n    'cultuur+hype':     'icoon',\n  };\n\n  function key(a, b) { return [a, b].sort().join('+'); }\n\n  let discovered = new Set(ELEMENTS.filter(e => e.starter).map(e => e.id));\n  let selected = null;\n  let notifTimer = null;\n\n  function getEl(id) { return ELEMENTS.find(e => e.id === id); }\n\n  function updateProgress() {\n    const badge = document.getElementById('progress-badge');\n    badge.textContent = discovered.size + ' / 12 ontdekt';\n    badge.className = discovered.size === 12 ? 'badge success' : 'badge';\n    if (discovered.size === 12) {\n      document.getElementById('win-banner').classList.add('visible');\n    }\n  }\n\n  function showNotif(msg, type, link) {\n    clearTimeout(notifTimer);\n    const el = document.getElementById('notification');\n    el.className = 'notification ' + (type || 'success') + ' visible';\n    el.innerHTML = msg + (link ? ' <a href=\"' + link + '\" target=\"_blank\">Bekijk het product →</a>' : '');\n    notifTimer = setTimeout(() => el.classList.remove('visible'), type === 'success' ? 5000 : 2500);\n  }\n\n  function renderGameGrid() {\n    const grid = document.getElementById('game-grid');\n    grid.innerHTML = '';\n    ELEMENTS.filter(e => discovered.has(e.id)).forEach(e => {\n      const card = document.createElement('div');\n      card.className = 'card' + (selected === e.id ? ' selected' : '') + (e.special ? ' special' : '');\n      card.innerHTML = '<span class=\"emoji\">' + e.emoji + '</span><span class=\"name\">' + e.name + '</span>' +\n        (e.starter ? '<span class=\"tag basis\">Basis</span>' : '') +\n        (e.special ? '<span class=\"tag speciaal\">Speciaal</span>' : '');\n      card.onclick = () => handleClick(e.id);\n      grid.appendChild(card);\n    });\n  }\n\n  function renderOverview() {\n    const grid = document.getElementById('overview-grid');\n    grid.innerHTML = '';\n    ELEMENTS.forEach(e => {\n      const card = document.createElement('div');\n      const isDisc = discovered.has(e.id);\n      card.className = 'overview-card' + (isDisc ? '' : ' locked');\n      card.innerHTML = '<span class=\"emoji\">' + (isDisc ? e.emoji : '🔒') + '</span>' +\n        '<span class=\"name\" style=\"font-size:0.75rem;color:#ccc;\">' + (isDisc ? e.name : '???') + '</span>' +\n        (isDisc && e.special ? '<br><a href=\"' + e.url + '\" target=\"_blank\" style=\"font-size:0.7rem;color:#f39c12;\">Bekijk product</a>' : '');\n      grid.appendChild(card);\n    });\n  }\n\n  function renderRecipes() {\n    const grid = document.getElementById('recipe-grid');\n    grid.innerHTML = '';\n    const recipes = [\n      { a: 'stof', b: 'verf', r: 'print' },\n      { a: 'stof', b: 'print', r: 'shirt' },\n      { a: 'straat', b: 'nacht', r: 'drop' },\n      { a: 'drop', b: 'shirt', r: 'hype' },\n      { a: 'hype', b: 'shirt', r: 'collectie' },\n      { a: 'collectie', b: 'straat', r: 'clvr_shirt' },\n      { a: 'straat', b: 'verf', r: 'cultuur' },\n      { a: 'cultuur', b: 'hype', r: 'icoon' },\n    ];\n    recipes.forEach(rec => {\n      const aEl = getEl(rec.a), bEl = getEl(rec.b), rEl = getEl(rec.r);\n      const canSee = discovered.has(rec.a) && discovered.has(rec.b);\n      const done = discovered.has(rec.r);\n      const card = document.createElement('div');\n      card.className = 'recipe-card';\n      card.innerHTML = (canSee\n        ? aEl.emoji + ' ' + aEl.name + ' + ' + bEl.emoji + ' ' + bEl.name\n        : '??? + ???') +\n        '<div class=\"result\">' + (done ? rEl.emoji + ' ' + rEl.name : '🔒 Onbekend') + '</div>';\n      grid.appendChild(card);\n    });\n  }\n\n  function render() {\n    renderGameGrid();\n    renderOverview();\n    renderRecipes();\n    updateProgress();\n  }\n\n  function handleClick(id) {\n    if (selected === null) {\n      selected = id;\n      document.getElementById('selected-indicator').style.display = 'block';\n      document.getElementById('selected-indicator').innerHTML =\n        '✋ Geselecteerd: ' + getEl(id).emoji + ' <strong>' + getEl(id).name + '</strong> — klik nu op een tweede element';\n      renderGameGrid();\n    } else {\n      const prev = selected;\n      selected = null;\n      document.getElementById('selected-indicator').style.display = 'none';\n      const k = key(prev, id);\n      const resultId = RECIPES[k];\n      if (resultId) {\n        const rEl = getEl(resultId);\n        if (discovered.has(resultId)) {\n          showNotif('Al ontdekt: ' + rEl.emoji + ' ' + rEl.name, 'info');\n        } else {\n          discovered.add(resultId);\n          if (rEl.special) {\n            showNotif('🎉 SPECIAAL ELEMENT ONTDEKT: ' + rEl.emoji + ' ' + rEl.name + '!', 'success', rEl.url);\n          } else {\n            showNotif('🎉 Nieuw element ontdekt: ' + rEl.emoji + ' ' + rEl.name + '!', 'success');\n          }\n        }\n      } else {\n        showNotif('Geen combinatie gevonden. Probeer iets anders!', 'info');\n      }\n      render();\n    }\n  }\n\n  window.resetGame = function() {\n    discovered = new Set(ELEMENTS.filter(e => e.starter).map(e => e.id));\n    selected = null;\n    document.getElementById('selected-indicator').style.display = 'none';\n    document.getElementById('win-banner').classList.remove('visible');\n    document.getElementById('notification').classList.remove('visible');\n    render();\n  };\n\n  render();\n})();\n</script>",
