{% doc %}
  @prompt
    Create a fullscreen hero video section for the homepage. The video should autoplay, be muted, and loop. It should cover the full width and height of the viewport (100vw x 100vh). The section should have an option to upload a video file. Optionally overlay a subtle dark gradient and support for a text overlay (brand name or tagline) centered on the video. Clean, minimal, premium streetwear aesthetic.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-hero-video-{{ ai_gen_id }} {
    position: relative;
    width: 100vw;
    height: 100vh;
    overflow: hidden;
    display: block;
    margin: 0;
    padding: 0;
  }

  .ai-hero-video__container-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  .ai-hero-video__video-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    min-width: 100%;
    min-height: 100%;
    width: auto;
    height: auto;
    transform: translate(-50%, -50%);
    object-fit: cover;
  }

  .ai-hero-video__placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: #0f0f0f;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-hero-video__placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 600px;
    max-height: 600px;
    opacity: 0.3;
  }

  .ai-hero-video__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 40px;
    left: 50%;
    transform: translateX(-50%);
    padding: 16px 32px;
    font-size: 16px;
    color: #ffffff;
    text-align: center;
    pointer-events: none;
    background-color: rgba(0, 0, 0, 0.5);
    border-radius: 4px;
  }

  {% if block.settings.enable_overlay %}
    .ai-hero-video__overlay-{{ ai_gen_id }} {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: linear-gradient(
        to bottom,
        rgba(0, 0, 0, {{ block.settings.overlay_opacity_top }}),
        rgba(0, 0, 0, {{ block.settings.overlay_opacity_bottom }})
      );
      pointer-events: none;
    }
  {% endif %}

  .ai-hero-video__content-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    text-align: center;
    z-index: 2;
    width: 90%;
    max-width: 1200px;
  }

  .ai-hero-video__heading-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-style: {{ block.settings.heading_font.style }};
    font-size: {{ block.settings.heading_size }}px;
    line-height: 1.1;
    color: {{ block.settings.text_color }};
    margin: 0 0 16px;
    letter-spacing: {{ block.settings.heading_letter_spacing }}px;
    text-transform: {% if block.settings.heading_uppercase %}uppercase{% else %}none{% endif %};
    text-shadow: 0 2px 8px rgba(0, 0, 0, {{ block.settings.text_shadow_opacity }});
  }

  .ai-hero-video__tagline-{{ ai_gen_id }} {
    font-family: {{ block.settings.tagline_font.family }}, {{ block.settings.tagline_font.fallback_families }};
    font-weight: {{ block.settings.tagline_font.weight }};
    font-style: {{ block.settings.tagline_font.style }};
    font-size: {{ block.settings.tagline_size }}px;
    line-height: 1.4;
    color: {{ block.settings.text_color }};
    margin: 0;
    letter-spacing: {{ block.settings.tagline_letter_spacing }}px;
    text-shadow: 0 2px 8px rgba(0, 0, 0, {{ block.settings.text_shadow_opacity }});
  }

  @media screen and (max-width: 749px) {
    .ai-hero-video__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.6 }}px;
    }

    .ai-hero-video__tagline-{{ ai_gen_id }} {
      font-size: {{ block.settings.tagline_size | times: 0.8 }}px;
    }
  }
{% endstyle %}

<hero-video-{{ ai_gen_id }} class="ai-hero-video-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-hero-video__container-{{ ai_gen_id }}">
    {% if block.settings.video %}
      <video
        class="ai-hero-video__video-{{ ai_gen_id }}"
        autoplay
        muted
        loop
        playsinline
        aria-label="Hero background video"
      >
        {% for source in block.settings.video.sources %}
          <source src="{{ source.url }}" type="{{ source.mime_type }}">
        {% endfor %}
      </video>
    {% else %}
      <div class="ai-hero-video__placeholder-{{ ai_gen_id }}">
        {{ 'hero-apparel-1' | placeholder_svg_tag }}
        <div class="ai-hero-video__empty-state-{{ ai_gen_id }}">
          Next, upload a video file
        </div>
      </div>
    {% endif %}

    {% if block.settings.enable_overlay %}
      <div class="ai-hero-video__overlay-{{ ai_gen_id }}"></div>
    {% endif %}

    {% if block.settings.heading != blank or block.settings.tagline != blank %}
      <div class="ai-hero-video__content-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h1 class="ai-hero-video__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h1>
        {% endif %}
        {% if block.settings.tagline != blank %}
          <p class="ai-hero-video__tagline-{{ ai_gen_id }}">{{ block.settings.tagline }}</p>
        {% endif %}
      </div>
    {% endif %}
  </div>
</hero-video-{{ ai_gen_id }}>

<script>
  (function() {
    class HeroVideo{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.video = this.querySelector('.ai-hero-video__video-{{ ai_gen_id }}');
        if (this.video) {
          this.ensureVideoPlays();
        }
      }

      ensureVideoPlays() {
        const playPromise = this.video.play();
        if (playPromise !== undefined) {
          playPromise.catch(() => {
            this.video.muted = true;
            this.video.play();
          });
        }
      }
    }

    customElements.define('hero-video-{{ ai_gen_id }}', HeroVideo{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Fullscreen hero video",
  "tag": null,
  "class": "ai-hero-video-block",
  "settings": [
    {
      "type": "header",
      "content": "Video"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Video file"
    },
    {
      "type": "header",
      "content": "Overlay"
    },
    {
      "type": "checkbox",
      "id": "enable_overlay",
      "label": "Enable gradient overlay",
      "default": true
    },
    {
      "type": "range",
      "id": "overlay_opacity_top",
      "label": "Top opacity",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "default": 0.3
    },
    {
      "type": "range",
      "id": "overlay_opacity_bottom",
      "label": "Bottom opacity",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "default": 0.5
    },
    {
      "type": "header",
      "content": "Text content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "CLVR"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "Premium streetwear essentials"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "text_shadow_opacity",
      "label": "Text shadow opacity",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "default": 0.5
    },
    {
      "type": "header",
      "content": "Heading style"
    },
    {
      "type": "font_picker",
      "id": "heading_font",
      "label": "Font",
      "default": "montserrat_n4"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Size",
      "min": 40,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "heading_letter_spacing",
      "label": "Letter spacing",
      "min": 0,
      "max": 10,
      "step": 1,
      "unit": "px",
      "default": 2
    },
    {
      "type": "checkbox",
      "id": "heading_uppercase",
      "label": "Uppercase",
      "default": true
    },
    {
      "type": "header",
      "content": "Tagline style"
    },
    {
      "type": "font_picker",
      "id": "tagline_font",
      "label": "Font",
      "default": "montserrat_n4"
    },
    {
      "type": "range",
      "id": "tagline_size",
      "label": "Size",
      "min": 12,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "tagline_letter_spacing",
      "label": "Letter spacing",
      "min": 0,
      "max": 6,
      "step": 1,
      "unit": "px",
      "default": 1
    }
  ],
  "presets": [
    {
      "name": "Fullscreen hero video"
    }
  ]
}
{% endschema %}
