{% doc %}
  @prompt
    Create a fullscreen hero video section with a Vimeo video hardcoded as a background. Use this exact iframe embed code: <iframe src="https://player.vimeo.com/video/1194319357?badge=0&autopause=0&player_id=0&app_id=58479&loop=1&autoplay=1&muted=1&background=1" frameborder="0" allow="autoplay; fullscreen; picture-in-picture" style="position:absolute;top:0;left:0;width:100%;height:100%;"></iframe>. The section should be 100vw x 100vh, the video fills the entire screen as a background, autoplay, muted, looping, no controls. Also include the Vimeo player.js script. No text overlay, no settings needed in the theme editor.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  #shopify-section-template--26973502800207__177936085488ade408 {
    padding: 0 !important;
    margin: 0 !important;
    max-width: 100% !important;
    width: 100vw !important;
    position: relative !important;
    left: 50% !important;
    right: 50% !important;
    margin-left: -50vw !important;
    margin-right: -50vw !important;
  }

  .ai-fullscreen-hero-{{ ai_gen_id }} {
    position: relative;
    width: 100vw;
    height: 100vh;
    overflow: hidden;
    margin: 0;
    padding: 0;
  }

  .ai-fullscreen-hero-video-wrapper-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }
{% endstyle %}

<div class="ai-fullscreen-hero-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-fullscreen-hero-video-wrapper-{{ ai_gen_id }}">
    <iframe id="vimeo-iframe-{{ ai_gen_id }}" src="https://player.vimeo.com/video/1194319357?badge=0&autopause=0&player_id=0&app_id=58479&loop=1&autoplay=1&muted=1&background=1" frameborder="0" allow="autoplay; fullscreen; picture-in-picture" style="position:absolute;top:10;left:10;width:100%;height:100%;"></iframe>
  </div>

  <!-- Text overlay -->
  <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);text-align:center;z-index:10;text-shadow:0 0 20px rgba(0, 0, 0, 0.8);">
    <h1 style="font-family:serif;font-size:80px;letter-spacing:2px;color:#ffd700;text-transform:uppercase;margin:0;">CLVR</h1>
    <p style="font-family:'Montserrat',sans-serif;font-size:18px;letter-spacing:1px;color:#ffd700;margin:8px 0 0;">Premium streetwear essentials</p>
  </div>

  <!-- Geluid knop -->
  <button id="sound-btn-{{ ai_gen_id }}" style="position:absolute;bottom:30px;right:30px;z-index:10;background:rgba(0,0,0,0.5);color:white;border:0px solid white;padding:8px 16px;cursor:pointer;font-family:'Montserrat',sans-serif;font-size:14px;">🔇 Sound</button>
</div>

<script src="https://player.vimeo.com/api/player.js"></script>
<script>
  var iframe = document.getElementById('vimeo-iframe-{{ ai_gen_id }}');
  var player = new Vimeo.Player(iframe);
  var muted = true;
  document.getElementById('sound-btn-{{ ai_gen_id }}').addEventListener('click', function() {
    muted = !muted;
    player.setMuted(muted);
    this.innerHTML = muted ? '🔇 Sound' : '🔊 Sound';
  });
</script>

{% schema %}
{
  "name": "Fullscreen hero video",
  "tag": null,
  "presets": [
    {
      "name": "Fullscreen hero video"
    }
  ]
}
{% endschema %}