{% doc %}
  @prompt
    Create a fullscreen hero video section with a Vimeo video hardcoded as a background. Use this exact iframe embed code: <iframe src="https://player.vimeo.com/video/1194319357?badge=0&autopause=0&player_id=0&app_id=58479&loop=1&autoplay=1&muted=1&background=1" frameborder="0" allow="autoplay; fullscreen; picture-in-picture" style="position:absolute;top:0;left:0;width:100%;height:100%;"></iframe>. The section should be 100vw x 100vh, the video fills the entire screen as a background, autoplay, muted, looping, no controls. Also include the Vimeo player.js script. No text overlay, no settings needed in the theme editor.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-fullscreen-hero-{{ ai_gen_id }} {
    position: relative;
    width: 100vw;
    height: 100vh;
    overflow: hidden;
    display: block;
    margin: 0;
    padding: 0;
  }

  .ai-fullscreen-hero-video-wrapper-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .ai-fullscreen-hero-video-wrapper-{{ ai_gen_id }} iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }
{% endstyle %}

<div class="ai-fullscreen-hero-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-fullscreen-hero-video-wrapper-{{ ai_gen_id }}">
    <iframe src="https://player.vimeo.com/video/1194319357?badge=0&autopause=0&player_id=0&app_id=58479&loop=1&autoplay=1&muted=1&background=1" frameborder="0" allow="autoplay; fullscreen; picture-in-picture" style="position:absolute;top:0;left:0;width:100%;height:100%;"></iframe>
  </div>
</div>

<script src="https://player.vimeo.com/api/player.js"></script>

{% schema %}
{
  "name": "Fullscreen hero video",
  "tag": null,
  "presets": [
    {
      "name": "Fullscreen hero video"
    }
  ]
}
{% endschema %}
