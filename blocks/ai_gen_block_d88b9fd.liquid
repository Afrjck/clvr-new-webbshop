{% doc %}
  @prompt
    Create a World Cup prediction widget section for a Shopify page with a dark premium streetwear aesthetic. Use EXACTLY the same layout structure as previously built versions of this widget for this store.
    
    LAYOUT STRUCTURE (must match exactly):
    - Full-width dark section, content centered in a max-width container
    - Top: contest header text
    - Below header: countdown timer with 4 boxes side by side (Days | Hours | Minutes | Seconds), each box has a large number and a small label underneath, gold border accent
    - Below timer: gold scarcity badge/pill
    - Below badge: form (email field full width, two score inputs side by side with team labels, goalscorers text field full width, social media handle field full width, full-width gold submit button)
    - Below form: success message (hidden until submit)
    - Below form: prizes section with two rows of prize text with emoji icons
    - All elements left-aligned within the container, generous padding
    
    DESIGN:
    - Dark background #000000, white text, gold accent #c9a84c
    - Minimal, editorial typography (clean sans-serif)
    - Form inputs: dark background #1a1a1a, subtle border #333333, white text
    - Submit button: gold background #c9a84c, black text, full width
    - Countdown boxes: dark background with gold border 2px solid #c9a84c
    
    CONTENT (ALL TEXT IN ENGLISH):
    - Header: "Morocco vs Haiti — June 25, 2026"
    - Live countdown timer to June 24 2026 23:50 CEST (June 24 2026 21:50 UTC) — boxes labeled "Days", "Hours", "Minutes", "Seconds"
    - After deadline show "Submissions are closed." and hide the form
    - Scarcity badge: "~12 shirts remaining" in gold
    - Form fields in this order:
      1. Email (required, label: "Your email address")
      2. Two side-by-side number inputs labeled "Morocco" and "Haiti" (min 0, integers only)
      3. Optional text field: "Goalscorers (optional)" with placeholder "e.g. Hakimi, En-Nesyri, Laguerre — comma-separated"
      4. Required text field: "Instagram or TikTok handle" with placeholder "@yourhandle" (required, so we can contact you if you win)
      5. Submit button: "Enter now"
    - Success message: "Your prediction has been saved! We'll let you know if you've won."
    - Prizes:
      - "🎯 Correct score → €15 discount"
      - "🏆 Correct score + goalscorer → Free shirt"
    
    FUNCTIONALITY:
    - Deadline: June 24 2026 23:50 CEST = June 24 2026 21:50:00 UTC
    - After deadline: hide form, show "Submissions are closed."
    - On submit: use fetch POST to /account with form_type create_customer, save customer email, add tags "wk-voorspelling" and "mar-hai-2026", store prediction AND social handle in customer note (format: "Prediction [mar-hai-2026]: SCORE | Goalscorers: X | Social: @handle")
    - DUPLICATE CHECK: only show "You've already entered!" if the email has ALREADY submitted a prediction for this contest (has tag mar-hai-2026 AND stored prediction). Do NOT block existing customers who have not yet submitted.
    - All text in English
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .wc-prediction-widget-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: #000000;
    padding: 60px 20px;
  }

  .wc-prediction-container-{{ ai_gen_id }} {
    max-width: 600px;
    margin: 0 auto;
  }

  .wc-prediction-header-{{ ai_gen_id }} {
    color: #ffffff;
    font-size: 28px;
    font-weight: 600;
    margin: 0 0 32px 0;
    text-align: left;
  }

  .wc-prediction-countdown-{{ ai_gen_id }} {
    display: flex;
    gap: 16px;
    margin-bottom: 24px;
  }

  .wc-prediction-countdown-box-{{ ai_gen_id }} {
    flex: 1;
    background-color: #000000;
    border: 2px solid #c9a84c;
    padding: 16px 8px;
    text-align: center;
  }

  .wc-prediction-countdown-number-{{ ai_gen_id }} {
    color: #ffffff;
    font-size: 32px;
    font-weight: 700;
    line-height: 1;
    margin-bottom: 8px;
  }

  .wc-prediction-countdown-label-{{ ai_gen_id }} {
    color: #c9a84c;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .wc-prediction-scarcity-{{ ai_gen_id }} {
    display: inline-block;
    background-color: transparent;
    border: 1px solid #c9a84c;
    color: #c9a84c;
    padding: 8px 16px;
    border-radius: 20px;
    font-size: 14px;
    margin-bottom: 32px;
  }

  .wc-prediction-form-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-bottom: 32px;
  }

  .wc-prediction-form-{{ ai_gen_id }}.hidden {
    display: none;
  }

  .wc-prediction-field-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .wc-prediction-label-{{ ai_gen_id }} {
    color: #ffffff;
    font-size: 14px;
    font-weight: 500;
  }

  .wc-prediction-input-{{ ai_gen_id }} {
    background-color: #1a1a1a;
    border: 1px solid #333333;
    color: #ffffff;
    padding: 12px 16px;
    font-size: 16px;
    border-radius: 4px;
    width: 100%;
  }

  .wc-prediction-input-{{ ai_gen_id }}::placeholder {
    color: #666666;
  }

  .wc-prediction-input-{{ ai_gen_id }}:focus {
    outline: none;
    border-color: #c9a84c;
  }

  .wc-prediction-score-row-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .wc-prediction-submit-{{ ai_gen_id }} {
    background-color: #c9a84c;
    color: #000000;
    border: none;
    padding: 16px 32px;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    border-radius: 4px;
    width: 100%;
    transition: opacity 0.3s ease;
  }

  .wc-prediction-submit-{{ ai_gen_id }}:hover {
    opacity: 0.9;
  }

  .wc-prediction-submit-{{ ai_gen_id }}:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .wc-prediction-success-{{ ai_gen_id }} {
    color: #c9a84c;
    font-size: 16px;
    margin-bottom: 24px;
    display: none;
  }

  .wc-prediction-success-{{ ai_gen_id }}.visible {
    display: block;
  }

  .wc-prediction-closed-{{ ai_gen_id }} {
    color: #ffffff;
    font-size: 18px;
    margin-bottom: 24px;
    display: none;
  }

  .wc-prediction-closed-{{ ai_gen_id }}.visible {
    display: block;
  }

  .wc-prediction-prizes-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .wc-prediction-prize-{{ ai_gen_id }} {
    color: #ffffff;
    font-size: 16px;
    line-height: 1.5;
  }

  .wc-prediction-error-{{ ai_gen_id }} {
    color: #ff6d6d;
    font-size: 14px;
    margin-top: 8px;
    display: none;
  }

  .wc-prediction-error-{{ ai_gen_id }}.visible {
    display: block;
  }

  @media screen and (max-width: 749px) {
    .wc-prediction-header-{{ ai_gen_id }} {
      font-size: 22px;
    }

    .wc-prediction-countdown-number-{{ ai_gen_id }} {
      font-size: 24px;
    }

    .wc-prediction-countdown-label-{{ ai_gen_id }} {
      font-size: 10px;
    }
  }
{% endstyle %}

<wc-prediction-widget-{{ ai_gen_id }} class="wc-prediction-widget-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="wc-prediction-container-{{ ai_gen_id }}">
    <h2 class="wc-prediction-header-{{ ai_gen_id }}">Morocco vs Haiti — June 25, 2026</h2>

    <div class="wc-prediction-countdown-{{ ai_gen_id }}" data-deadline="2026-06-24T21:50:00Z">
      <div class="wc-prediction-countdown-box-{{ ai_gen_id }}">
        <div class="wc-prediction-countdown-number-{{ ai_gen_id }}" data-unit="days">0</div>
        <div class="wc-prediction-countdown-label-{{ ai_gen_id }}">Days</div>
      </div>
      <div class="wc-prediction-countdown-box-{{ ai_gen_id }}">
        <div class="wc-prediction-countdown-number-{{ ai_gen_id }}" data-unit="hours">0</div>
        <div class="wc-prediction-countdown-label-{{ ai_gen_id }}">Hours</div>
      </div>
      <div class="wc-prediction-countdown-box-{{ ai_gen_id }}">
        <div class="wc-prediction-countdown-number-{{ ai_gen_id }}" data-unit="minutes">0</div>
        <div class="wc-prediction-countdown-label-{{ ai_gen_id }}">Minutes</div>
      </div>
      <div class="wc-prediction-countdown-box-{{ ai_gen_id }}">
        <div class="wc-prediction-countdown-number-{{ ai_gen_id }}" data-unit="seconds">0</div>
        <div class="wc-prediction-countdown-label-{{ ai_gen_id }}">Seconds</div>
      </div>
    </div>

    <div class="wc-prediction-scarcity-{{ ai_gen_id }}">~12 shirts remaining</div>

    <div class="wc-prediction-closed-{{ ai_gen_id }}">Submissions are closed.</div>

    <form class="wc-prediction-form-{{ ai_gen_id }}" data-form>
      <div class="wc-prediction-field-{{ ai_gen_id }}">
        <label class="wc-prediction-label-{{ ai_gen_id }}" for="email-{{ ai_gen_id }}">Your email address</label>
        <input
          type="email"
          id="email-{{ ai_gen_id }}"
          name="email"
          class="wc-prediction-input-{{ ai_gen_id }}"
          required
          autocomplete="email"
        >
      </div>

      <div class="wc-prediction-score-row-{{ ai_gen_id }}">
        <div class="wc-prediction-field-{{ ai_gen_id }}">
          <label class="wc-prediction-label-{{ ai_gen_id }}" for="morocco-{{ ai_gen_id }}">Morocco</label>
          <input
            type="number"
            id="morocco-{{ ai_gen_id }}"
            name="morocco"
            class="wc-prediction-input-{{ ai_gen_id }}"
            min="0"
            step="1"
            required
          >
        </div>
        <div class="wc-prediction-field-{{ ai_gen_id }}">
          <label class="wc-prediction-label-{{ ai_gen_id }}" for="haiti-{{ ai_gen_id }}">Haiti</label>
          <input
            type="number"
            id="haiti-{{ ai_gen_id }}"
            name="haiti"
            class="wc-prediction-input-{{ ai_gen_id }}"
            min="0"
            step="1"
            required
          >
        </div>
      </div>

      <div class="wc-prediction-field-{{ ai_gen_id }}">
        <label class="wc-prediction-label-{{ ai_gen_id }}" for="goalscorers-{{ ai_gen_id }}">Goalscorers (optional)</label>
        <input
          type="text"
          id="goalscorers-{{ ai_gen_id }}"
          name="goalscorers"
          class="wc-prediction-input-{{ ai_gen_id }}"
          placeholder="e.g. Hakimi, En-Nesyri, Laguerre — comma-separated"
        >
      </div>

      <div class="wc-prediction-field-{{ ai_gen_id }}">
        <label class="wc-prediction-label-{{ ai_gen_id }}" for="social-{{ ai_gen_id }}">Instagram or TikTok handle</label>
        <input
          type="text"
          id="social-{{ ai_gen_id }}"
          name="social"
          class="wc-prediction-input-{{ ai_gen_id }}"
          placeholder="@yourhandle"
          required
        >
      </div>

      <div class="wc-prediction-error-{{ ai_gen_id }}" data-error></div>

      <button type="submit" class="wc-prediction-submit-{{ ai_gen_id }}">Enter now</button>
    </form>

    <div class="wc-prediction-success-{{ ai_gen_id }}" data-success>
      Your prediction has been saved! We'll let you know if you've won.
    </div>

    <div class="wc-prediction-prizes-{{ ai_gen_id }}">
      <div class="wc-prediction-prize-{{ ai_gen_id }}">🎯 Correct score → €15 discount</div>
      <div class="wc-prediction-prize-{{ ai_gen_id }}">🏆 Correct score + goalscorer → Free shirt</div>
    </div>
  </div>
</wc-prediction-widget-{{ ai_gen_id }}>

<script>
  (function() {
    class WCPredictionWidget{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.countdown = this.querySelector('[data-deadline]');
        this.form = this.querySelector('[data-form]');
        this.successMessage = this.querySelector('[data-success]');
        this.errorMessage = this.querySelector('[data-error]');
        this.closedMessage = this.querySelector('.wc-prediction-closed-{{ ai_gen_id }}');
        this.deadline = new Date('2026-06-24T21:50:00Z');
        this.contestTag = 'mar-hai-2026';
      }

      connectedCallback() {
        this.startCountdown();
        this.setupForm();
      }

      startCountdown() {
        const updateCountdown = () => {
          const now = new Date();
          const diff = this.deadline - now;

          if (diff <= 0) {
            this.showClosed();
            return;
          }

          const days = Math.floor(diff / (1000 * 60 * 60 * 24));
          const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
          const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
          const seconds = Math.floor((diff % (1000 * 60)) / 1000);

          this.querySelector('[data-unit="days"]').textContent = days;
          this.querySelector('[data-unit="hours"]').textContent = hours;
          this.querySelector('[data-unit="minutes"]').textContent = minutes;
          this.querySelector('[data-unit="seconds"]').textContent = seconds;
        };

        updateCountdown();
        setInterval(updateCountdown, 1000);
      }

      showClosed() {
        this.form.classList.add('hidden');
        this.closedMessage.classList.add('visible');
      }

setupForm() {
  this.form.addEventListener('submit', async (e) => {
    e.preventDefault();

    const now = new Date();
    if (now >= this.deadline) {
      this.showClosed();
      return;
    }

    const formData = new FormData(this.form);
    const email = formData.get('email');
    const morocco = formData.get('morocco');
    const haiti = formData.get('haiti');
    const goalscorers = formData.get('goalscorers') || 'None';
    const social = formData.get('social');

    this.errorMessage.classList.remove('visible');
    this.errorMessage.textContent = '';

    const submitButton = this.form.querySelector('button[type="submit"]');
    submitButton.disabled = true;
    submitButton.textContent = 'Submitting...';

    try {
      const prediction = `Prediction [${this.contestTag}]: ${morocco}-${haiti} | Goalscorers: ${goalscorers} | Social: ${social}`;

      const response = await fetch('/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: new URLSearchParams({
          'form_type': 'contact',
          'utf8': '✓',
          'contact[email]': email,
          'contact[body]': prediction
        })
      });

      if (response.ok) {
        this.form.classList.add('hidden');
        this.successMessage.classList.add('visible');
      } else {
        this.errorMessage.textContent = 'Something went wrong. Please try again.';
        this.errorMessage.classList.add('visible');
        submitButton.disabled = false;
        submitButton.textContent = 'Enter now';
      }
    } catch (error) {
      this.errorMessage.textContent = 'Something went wrong. Please try again.';
      this.errorMessage.classList.add('visible');
      submitButton.disabled = false;
      submitButton.textContent = 'Enter now';
    }
  });
}
    }

    customElements.define('wc-prediction-widget-{{ ai_gen_id }}', WCPredictionWidget{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "World Cup prediction",
  "settings": [
    {
      "type": "paragraph",
      "content": "Morocco vs Haiti prediction widget with countdown timer, form submission, and prize display. Deadline: June 24, 2026 23:50 CEST."
    }
  ],
  "presets": [
    {
      "name": "World Cup prediction"
    }
  ]
}
{% endschema %}