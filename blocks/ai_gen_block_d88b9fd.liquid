{% doc %}
  @prompt
    Create a World Cup prediction widget section for a Shopify page with a dark premium streetwear aesthetic. Use EXACTLY the same layout structure as previously built versions of this widget for this store.
    
    LAYOUT STRUCTURE (must match exactly):
    - Full-width dark section, content centered in a max-width container
    - Top: contest header text
    - Below header: countdown timer with 4 boxes side by side (Days | Hours | Minutes | Seconds), each box has a large number and a small label underneath, gold border accent
    - Below timer: gold scarcity badge/pill
    - Below badge: form (email field full width, two score inputs side by side with team labels, goalscorers text field full width, social media handle field full width, full-width gold submit button)
    - Below form: success message (hidden until submit)
    - Below form: prizes section with two rows of prize text with emoji icons
    - All elements left-aligned within the container, generous padding
    
    DESIGN:
    - Dark background #000000, white text, gold accent #c9a84c
    - Minimal, editorial typography (clean sans-serif)
    - Form inputs: dark background #1a1a1a, subtle border #333333, white text
    - Submit button: gold background #c9a84c, black text, full width
    - Countdown boxes: dark background with gold border 2px solid #c9a84c
    
    CONTENT (ALL TEXT IN ENGLISH):
    - Header: "Morocco vs Haiti — June 25, 2026"
    - Live countdown timer to June 24 2026 23:50 CEST (June 24 2026 21:50 UTC) — boxes labeled "Days", "Hours", "Minutes", "Seconds"
    - After deadline show "Submissions are closed." and hide the form
    - Scarcity badge: "~12 shirts remaining" in gold
    - Form fields in this order:
      1. Email (required, label: "Your email address")
      2. Two side-by-side number inputs labeled "Morocco" and "Haiti" (min 0, integers only)
      3. Optional text field: "Goalscorers (optional)" with placeholder "e.g. Hakimi, En-Nesyri, Laguerre — comma-separated"
      4. Required text field: "Instagram or TikTok handle" with placeholder "@yourhandle" (required, so we can contact you if you win)
      5. Submit button: "Enter now"
    - Success message: "Your prediction has been saved! We'll let you know if you've won."
    - Prizes:
      - "🎯 Correct score → €15 discount"
      - "🏆 Correct score + goalscorer → Free shirt"
    
    FUNCTIONALITY:
    - Deadline: June 24 2026 23:50 CEST = June 24 2026 21:50:00 UTC
    - After deadline: hide form, show "Submissions are closed."
    - On submit: use fetch POST to /account with form_type create_customer, save customer email, add tags "wk-voorspelling" and "mar-hai-2026", store prediction AND social handle in customer note (format: "Prediction [mar-hai-2026]: SCORE | Goalscorers: X | Social: @handle")
    - DUPLICATE CHECK: only show "You've already entered!" if the email has ALREADY submitted a prediction for this contest (has tag mar-hai-2026 AND stored prediction). Do NOT block existing customers who have not yet submitted.
    - All text in English
{% enddoc %}

{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .wc-widget-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: #000000;
    padding: 60px 20px;
  }
  .wc-container-{{ ai_gen_id }} {
    max-width: 600px;
    margin: 0 auto;
  }
  .wc-header-{{ ai_gen_id }} {
    color: #ffffff;
    font-size: 28px;
    font-weight: 600;
    margin: 0 0 32px 0;
  }
  .wc-countdown-{{ ai_gen_id }} {
    display: flex;
    gap: 16px;
    margin-bottom: 24px;
  }
  .wc-countdown-box-{{ ai_gen_id }} {
    flex: 1;
    background-color: #000000;
    border: 2px solid #c9a84c;
    padding: 16px 8px;
    text-align: center;
  }
  .wc-countdown-number-{{ ai_gen_id }} {
    color: #ffffff;
    font-size: 32px;
    font-weight: 700;
    line-height: 1;
    margin-bottom: 8px;
  }
  .wc-countdown-label-{{ ai_gen_id }} {
    color: #c9a84c;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .wc-badge-{{ ai_gen_id }} {
    display: inline-block;
    border: 1px solid #c9a84c;
    color: #c9a84c;
    padding: 8px 16px;
    border-radius: 20px;
    font-size: 14px;
    margin-bottom: 32px;
  }
  .wc-closed-{{ ai_gen_id }} {
    color: #ffffff;
    font-size: 18px;
    margin-bottom: 24px;
    display: none;
  }
  .wc-closed-{{ ai_gen_id }}.visible { display: block; }
  .wc-form-wrap-{{ ai_gen_id }} {
    margin-bottom: 32px;
  }
  .wc-form-wrap-{{ ai_gen_id }}.hidden { display: none; }
  .wc-form-inner-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .wc-field-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .wc-label-{{ ai_gen_id }} {
    color: #ffffff;
    font-size: 14px;
    font-weight: 500;
  }
  .wc-input-{{ ai_gen_id }} {
    background-color: #1a1a1a;
    border: 1px solid #333333;
    color: #ffffff;
    padding: 12px 16px;
    font-size: 16px;
    border-radius: 4px;
    width: 100%;
    box-sizing: border-box;
  }
  .wc-input-{{ ai_gen_id }}::placeholder { color: #666666; }
  .wc-input-{{ ai_gen_id }}:focus { outline: none; border-color: #c9a84c; }
  .wc-score-row-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  .wc-submit-{{ ai_gen_id }} {
    background-color: #c9a84c;
    color: #000000;
    border: none;
    padding: 16px 32px;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    border-radius: 4px;
    width: 100%;
  }
  .wc-submit-{{ ai_gen_id }}:hover { opacity: 0.9; }
  .wc-success-{{ ai_gen_id }} {
    color: #c9a84c;
    font-size: 16px;
    margin-bottom: 24px;
    padding: 16px;
    border: 1px solid #c9a84c;
    border-radius: 4px;
  }
  .wc-prizes-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .wc-prize-{{ ai_gen_id }} {
    color: #ffffff;
    font-size: 16px;
    line-height: 1.5;
  }
  @media screen and (max-width: 749px) {
    .wc-header-{{ ai_gen_id }} { font-size: 22px; }
    .wc-countdown-number-{{ ai_gen_id }} { font-size: 24px; }
    .wc-countdown-label-{{ ai_gen_id }} { font-size: 10px; }
  }
{% endstyle %}

<div class="wc-widget-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="wc-container-{{ ai_gen_id }}">
    <h2 class="wc-header-{{ ai_gen_id }}">Morocco vs Haiti — June 25, 2026</h2>

    <div class="wc-countdown-{{ ai_gen_id }}">
      <div class="wc-countdown-box-{{ ai_gen_id }}">
        <div class="wc-countdown-number-{{ ai_gen_id }}" id="wc-days-{{ ai_gen_id }}">0</div>
        <div class="wc-countdown-label-{{ ai_gen_id }}">Days</div>
      </div>
      <div class="wc-countdown-box-{{ ai_gen_id }}">
        <div class="wc-countdown-number-{{ ai_gen_id }}" id="wc-hours-{{ ai_gen_id }}">0</div>
        <div class="wc-countdown-label-{{ ai_gen_id }}">Hours</div>
      </div>
      <div class="wc-countdown-box-{{ ai_gen_id }}">
        <div class="wc-countdown-number-{{ ai_gen_id }}" id="wc-minutes-{{ ai_gen_id }}">0</div>
        <div class="wc-countdown-label-{{ ai_gen_id }}">Minutes</div>
      </div>
      <div class="wc-countdown-box-{{ ai_gen_id }}">
        <div class="wc-countdown-number-{{ ai_gen_id }}" id="wc-seconds-{{ ai_gen_id }}">0</div>
        <div class="wc-countdown-label-{{ ai_gen_id }}">Seconds</div>
      </div>
    </div>

    <div class="wc-badge-{{ ai_gen_id }}">~12 shirts remaining</div>
    <div class="wc-closed-{{ ai_gen_id }}" id="wc-closed-{{ ai_gen_id }}">Submissions are closed.</div>

    <div class="wc-form-wrap-{{ ai_gen_id }}" id="wc-formwrap-{{ ai_gen_id }}">
      {% form 'contact' %}
        {% if form.posted_successfully? %}
          <div class="wc-success-{{ ai_gen_id }}">Your prediction has been saved! We'll let you know if you've won.</div>
        {% else %}
          <div class="wc-form-inner-{{ ai_gen_id }}">
            <input type="hidden" name="contact[subject]" value="WK Prediction: Morocco vs Haiti">

            <div class="wc-field-{{ ai_gen_id }}">
              <label class="wc-label-{{ ai_gen_id }}" for="wc-email-{{ ai_gen_id }}">Your email address</label>
              <input type="email" id="wc-email-{{ ai_gen_id }}" name="contact[email]" class="wc-input-{{ ai_gen_id }}" required autocomplete="email">
            </div>

            <div class="wc-score-row-{{ ai_gen_id }}">
              <div class="wc-field-{{ ai_gen_id }}">
                <label class="wc-label-{{ ai_gen_id }}" for="wc-morocco-{{ ai_gen_id }}">Morocco</label>
                <input type="number" id="wc-morocco-{{ ai_gen_id }}" name="contact[morocco_score]" class="wc-input-{{ ai_gen_id }}" min="0" step="1" required>
              </div>
              <div class="wc-field-{{ ai_gen_id }}">
                <label class="wc-label-{{ ai_gen_id }}" for="wc-haiti-{{ ai_gen_id }}">Haiti</label>
                <input type="number" id="wc-haiti-{{ ai_gen_id }}" name="contact[haiti_score]" class="wc-input-{{ ai_gen_id }}" min="0" step="1" required>
              </div>
            </div>

            <div class="wc-field-{{ ai_gen_id }}">
              <label class="wc-label-{{ ai_gen_id }}" for="wc-goalscorers-{{ ai_gen_id }}">Goalscorers (optional)</label>
              <input type="text" id="wc-goalscorers-{{ ai_gen_id }}" name="contact[goalscorers]" class="wc-input-{{ ai_gen_id }}" placeholder="e.g. Hakimi, En-Nesyri, Laguerre — comma-separated">
            </div>

            <div class="wc-field-{{ ai_gen_id }}">
              <label class="wc-label-{{ ai_gen_id }}" for="wc-social-{{ ai_gen_id }}">Instagram or TikTok handle</label>
              <input type="text" id="wc-social-{{ ai_gen_id }}" name="contact[social]" class="wc-input-{{ ai_gen_id }}" placeholder="@yourhandle" required>
            </div>

            <button type="submit" class="wc-submit-{{ ai_gen_id }}">Enter now</button>
          </div>
        {% endif %}
      {% endform %}
    </div>

    <div class="wc-prizes-{{ ai_gen_id }}">
      <div class="wc-prize-{{ ai_gen_id }}">🎯 Correct score → €15 discount</div>
      <div class="wc-prize-{{ ai_gen_id }}">🏆 Correct score + goalscorer → Free shirt</div>
    </div>
  </div>
</div>

<script>
(function() {
  var deadline = new Date('2026-06-24T21:50:00Z');
  var daysEl = document.getElementById('wc-days-{{ ai_gen_id }}');
  var hoursEl = document.getElementById('wc-hours-{{ ai_gen_id }}');
  var minutesEl = document.getElementById('wc-minutes-{{ ai_gen_id }}');
  var secondsEl = document.getElementById('wc-seconds-{{ ai_gen_id }}');
  var closedEl = document.getElementById('wc-closed-{{ ai_gen_id }}');
  var formWrap = document.getElementById('wc-formwrap-{{ ai_gen_id }}');

  function updateCountdown() {
    var diff = deadline - new Date();
    if (diff <= 0) {
      if (formWrap) formWrap.classList.add('hidden');
      if (closedEl) closedEl.classList.add('visible');
      clearInterval(timer);
      return;
    }
    daysEl.textContent = Math.floor(diff / 86400000);
    hoursEl.textContent = Math.floor((diff % 86400000) / 3600000);
    minutesEl.textContent = Math.floor((diff % 3600000) / 60000);
    secondsEl.textContent = Math.floor((diff % 60000) / 1000);
  }

  updateCountdown();
  var timer = setInterval(updateCountdown, 1000);
})();
</script>

{% schema %}
{
  "name": "World Cup prediction",
  "settings": [],
  "presets": [{ "name": "World Cup prediction" }]
}
{% endschema %}
